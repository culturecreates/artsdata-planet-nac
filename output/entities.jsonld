      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Lennie Gallant | The Innkeeper's Christmas |  Sat, Nov 28, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41632/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come join Lennie Gallant and his band for some Christmas Cheer! Lennie is excited to bring his Christmas concert to you this year. This holiday favourite is full of original Christmas songs, stories and exciting accompanying visuals on screen! Lennie and his amazing band will bring you laughs, lots of wonder, and maybe a few tears, as they look at Christmas from many points of view in 2026. Don’t miss this unique Yuletide Feast for the eyes, ears and heart! \n\nWinner..."
      }
    ],
