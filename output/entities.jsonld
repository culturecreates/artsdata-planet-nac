      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Gabriella Olivo | Reflexiones |  Fri, Oct 23, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41588/rounded_corner_design_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Originally from Québec City, Gabriella Olivo was born to a Mexican mother and a Québécois father. She revisits her Mexican heritage in Spanish-language songs steeped in a subtle, gentle indie-pop sound. Somewhere between daydream and introspection, her airy compositions and soft voice draw listeners into a world of love, passion and heartbreak. Her energy on stage is spellbinding, whisking the audience away to a place of tenderness and melancholy. \n\nGabriella Olivo, nacida y criada en la ciudad de Quebec de madre..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
