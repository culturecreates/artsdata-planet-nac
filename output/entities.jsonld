      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dreamcatcher Workshop | with Bougie Birch |  Fri, May 15, 2026, 5:30 pm | Atelier Shenkman Smith"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40672/20241219-still_2024-12-19_231420_1.10.2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us in the NAC’s Atelier Shenkman Smith for Bougie Birch's Dreamcatcher Workshop. Under the guidance of Indigenous artist and educator, Ashley Clark, craft your own dreamcatcher in a 1.5-2 hour session. We supply the materials; you bring the inspiration.\nDive into Indigenous artistry, learn about the resilience of Indigenous communities throughout history, and be part of a hands-on experience that bridges cultures. With Bougie Birch, it's more than a craft – it's a journey into heritage. Come, connect, and create.\n\nThis..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
