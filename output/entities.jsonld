      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Golden voices of Arabia | The Eternal Echoes of Arab Divas  |  Sat, May 23, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40095/gvoa_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Nidal Ibourk is an exceptional artist, scholar, and singer based in Montreal, Canada. She was born in Rabat, Morocco and moved to the United States to pursue her graduate studies. Her amazing talent as a singer was recognized early in the Arab world after competing in many international music shows. \n\nNidal performed in major performing arts centers in the U.S, Canada and Europe, such as the Institut du Monde Arabe in France, New York World Music Institute, San Diego Museum of Contemporary Art, Detroit Music Hall, Lincoln Theater, Chicago Millennium..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
