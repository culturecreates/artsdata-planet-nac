    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "J3M | Jukebox Lunch Concerts |  Thu, Jun 25, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41096/j3m-bts-02629_(1)_-_j3m__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Get ready for a Jukebox performance featuring J3M, one of the 2026 Capital Music Awards Music Video of the Year nominees! \n\nJ3M is a slick combination of pop and disco guaranteed to live in your head rent-free. The singer-songwriter-producer (and 2-time JUNO-nominated pianist) has backed artists like The OBGMs, Kellie Loder, Tanika Charles and more, locally and internationally. Sharing stages with Jully Black & Cyndi Lauper, just to name a few, J3M is no stranger to the industry, making appearances at..."
      }
    ],
