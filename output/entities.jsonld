    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dana Sipos |  Thu, Oct 22, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
