      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "L'Orestie  | The iconic classical trilogy revisited by Alice Ronfard | Nov 5 - 7, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40439/tfcna2627_orestie_1920x1080__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "After taking on Michel Tremblay’s body of work in the unforgettable Traversée du siècle, Alice Ronfard tackles the seminal text of Western theatre, if not of Western thought. Like an ambitious theatrical river, her adaptation flows from ancient Greece to the present day, carrying with it the timeless question of justice. Three tragedies, about thirty performers (including a large chorus and three musicians): an epic journey through the centuries.\n\nWhen King Agamemnon sacrifices his daughter, Iphigenia, to the gods, his wife, Clytemnestra,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
