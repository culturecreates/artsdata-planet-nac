    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Aviva Chernick and La Serena Quartet  | The Feeling of Free |  Wed, Aug 26, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40940/aviva_chernick_and_la_serena_quartet_horizontal_3782_indoors_by_curtis_perry__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to recharge for the rest of the day! \n\nSinger and bandleader Aviva Chernick reimagines traditional Judaeo-Spanish folk music with intimacy and emotional range. Aviva and her band bring this musical legacy into the present. \n\nAviva’s soaring vocals in the Judaeo-Spanish language, Ladino, as well as Hebrew, Yiddish and English, combine with the musical talents and..."
      }
    ],
