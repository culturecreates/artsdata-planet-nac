    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Miguel de Armas | The Feeling of Free |  Sat, Jul 4, 2026, 4:30 pm | Along the Rideau Canal"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40976/dscf0317_curtis_perry__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "El español sigue al texto en inglés\n\nMiguel de Armas is an internationally acclaimed Cuban pianist, composer, and arranger who has been captivating Canadian audiences since moving to Ottawa in 2012. With over 35 years of experience and more than 60 albums to his name, Miguel has dedicated his career to blending the vibrant rhythms of Afro-Cuban music with contemporary jazz, creating a rich and dynamic musical experience. \n\nFor this special performance at the National Arts Centre, Miguel invites audiences on a..."
      }
    ],
