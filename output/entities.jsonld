    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Takuya Kuroda |  Fri, Jun 19, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41118/copy_of_ojf_2026_showpass_1200x600_takuya_kuroda__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Kobe-born and Brooklyn-based, trumpeter Takuya Kuroda continues to redefine modern jazz through a relentless, “everyday” work ethic. His eighth studio album, Everyday (2025), serves as a rhythmic triumph that deepens his signature fusion of hip-hop, neo-soul, and post-bop. A graduate of The New School and a veteran of the New York scene, Kuroda has spent over two decades collaborating with icons like DJ Premier’s Badder Band and recording for legendary labels like Blue Note. On his latest project, he meticulously..."
      }
    ],
