    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kozé |  Fri, Apr 24, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40760/4_1772131677_koze_3_djimillei_ally_2025__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The group Kozé was formed by lovers of maloya who wanted to introduce this form of music to audiences in Quebec and, more broadly, in Canada. Kozé means “to speak, to communicate” in Réunion Creole, and it is through its lyrics and songs that the group conveys its message and values. Maloya is protest music that combines percussion and singing, a beautiful way for its choral voices to resonate with drums and other native Réunion Island instruments. Experience Kozé’s maloya,..."
      }
    ],
