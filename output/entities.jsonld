    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dálava |  Sun, Jun 21, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40356/4_1768334772_copy_of_daYlava_-_by_alysha_seriani__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Dálava, led by vocalist Julia Úlehla and guitarist Aram Bajakian, is a genre-defying ensemble that fuses Moravian folk traditions with experimental improvisation. Their new album Understories draws on folk songs transcribed by Úlehla’s great-grandfather, Vladimír Úlehla, creating music that exists in a liminal space between past and present, magic and realism. With hypnotic vocals that range from whisper to holler, Julia channels the emotional and metaphysical depth of these songs, while Bajakian’s adventurous guitar work and contributions from Peggy Lee..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
