      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ravel & Shostakovich | Darren Hicks Plays Jolivet | Apr 1 - 2, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38411/16__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tConductor Andrey Boreyko returns to Southam Hall to lead a program celebrating the ravishing sounds of the NAC Orchestra’s woodwind players.\n\tWorks originally written for solo piano and string quartet by Maurice Ravel and Dmitri Shostakovich take on new life in vivid arrangements for orchestra.\n\tThe NAC Orchestra’s Principal Bassoon Darren Hicks showcases his instrument’s versatile voice in André Jolivet’s Bassoon Concerto.\n\n\nComposed as First World War raged across Europe, Maurice Ravel’s Le Tombeau de Couperin reaches across time to honour the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
