    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Al Qahwa |  Thu, May 28, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40837/maryem_tollar_folk_alliance_2025_choice_je7a5739_(1)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Al Qahwa is a Toronto-based ensemble inspired by the spirit of the great Middle Eastern coffee houses — gathering places where music, poetry, and bold ideas were shared late into the night. Rooted in Arabic musical traditions yet alive with jazz, global rhythms, and fearless improvisation, Al Qahwa creates music that feels both ancient and immediate — music of migration, memory, and connection.\n\nAt its heart is award-winning vocalist Maryem Tollar, an artist whose voice defies borders. Born in Cairo and..."
      }
    ],
