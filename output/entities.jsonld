    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Moulin Rouge! The Musical | May 12 - 17, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38563/00_bac_seasons25-26_1440x810_nacwebsite_productionshots_mro__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Pop the champagne, Moulin Rouge! The Musical is the winner of 10 Tony Awards®—including Best Musical! Enter a world of splendor and romance, of eye-popping excess, of glitz, grandeur, and glory! A world where bohemians and aristocrats rub elbows and revel in electrifying enchantment. Welcome to Moulin Rouge! The Musical Baz Luhrmann’s revolutionary film comes to life onstage, remixed in a new musical mash-up extravaganza. Directed by Tony Award® winner Alex Timbers, Moulin Rouge! The Musical is a theatrical celebration..."
      }
    ],
