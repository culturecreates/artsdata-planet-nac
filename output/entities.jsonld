      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ottawa Jazz Orchestra | Coltrane 100 | Nov 18 - 19, 2026 | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41709/coltrane_100__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Marking a monumental milestone in music history, the Ottawa Jazz Orchestra proudly presents a centennial celebration of the life, spirit, and unmatched genius of John Coltrane. This programme, with 19 musicians, will feature two seminal large-scale works with Coltrane’s masterwork, Africa/Brass and a deeply moving, full big-band reimagining of his spiritual masterpiece, A Love Supreme. Join us for a reverent, powerful, and historically rich tribute to one of the greatest architects of American music."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
