    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sensei H |  Thu, Mar 5, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40321/web_resize_(2)_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Drawing inspiration from theatre and documentary film, Sensei H is back with a show that defies the conventions of rap and showcases her signature charisma. The intention is clear: to deliver an extraordinary experience. La mort du troisième couplet (“the death of the third verse”) embraces a deliberate sonic eclecticism, ranging from house to trap-rock by way of pure hip-hop, that unfolds on stage in a fusion of electronic and acoustic music.\n\nA Franco-Algerian artist now based in Quebec City, Sensei..."
      }
    ],
