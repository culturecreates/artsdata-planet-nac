    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Agamemnon in the Ring | Wrestling in verse |  Fri, Apr 24, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38322/tfcna2526_agamemnoninthering_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "This show is presented in French.\n\nAdults, youth from age 13 welcome.\n\nCheap shot! A belligerent trio from the Troy-Rivières wrestling league has snatched the National League gold belt from the champion of champions, Agamemnon! Will the recent retiree climb back into his spandex singlet to defend his honour at the terrible cost of sacrificing his own heiress, Eugénie? This ancient epic, told in the form of a wrestling rumble, will unleash your inner beast!\n\nTwelve imposing wrestlers take the stage to defend this reinterpretation of..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
