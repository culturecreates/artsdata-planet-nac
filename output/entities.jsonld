    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Karanfil/Carnation | Laura Taler / Grimm Pictures  |  Mon, May 4, 2026, 7:00 pm | Rehearsal Hall A"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40241/lt_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "NAC Dance presents an in-person special screening of an NAC Dance Commission. Join Laura Taler backstage at the NAC to watch the film she created backstage at the NAC!  \n\nLaura Taler brings us on a site-specific cinematic journey through the NAC’s theatrical underworld where the art of crafting private dreams is made public. While conjuring a ninety-nine-year-old photo of Bronislava Nijinska, Taler poses a series of questions about performance, the fallibility and concreteness of language, and the practice of turning the self inside out.   \n\nKaranfil/Carnation features musical performances..."
      }
    ],
