    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Program notes: Schubert’s Monumental Ninth Symphony"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38415/dscf0040_curtis_perry_(1)_cropped__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "What you need to know: Schubert’s monumental Ninth Symphony anchors the evening with a sweeping, high-energy journey that builds toward a powerful, triumphant finale. The first half explores French romantic intimacy through Berlioz’s Les Nuits..."
      }
    ],
