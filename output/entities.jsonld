      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Natalie MacMaster & Donnell Leahy | A Celtic Family Christmas with Mary Frances | Dec 19, 2026  | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41225/untitled_design_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Get ready for the brand-new Celtic Family Christmas… PARTY! At the NAC, we’re sharing the Christmas spirit with the entire city! This season, the well-loved fiddle-playing MacMaster Leahy family is bringing light and happiness to families and fans across the country. \n\nYou’ll have plenty of time to sip eggnog by the fire, but not on this night…  So, buckle up and join Natalie MacMaster and Donnell Leahy, their growing family, and their world-class band as they guide you through an exhilarating exploration..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
