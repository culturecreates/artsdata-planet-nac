    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "MÁM | Teaċ Daṁsa │Michael Keegan-Dolan | Sep 25 - 26, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40372/mam_-_dublin_theatre_festival_2019_-_ros_kavanagh_4__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Revelry and Ritual\n\nThe works of Irish choreographer Michael Keegan-Dolan are defined by feeling and collective connection. His exceptional dance-theatre productions skillfully integrate pathos and humour, and draw on themes of love and identity.\n\nBringing together virtuoso Irish traditional concertina player Cormac Begley, contemporary music collective s t a r g a z e, and an ensemble of twelve dancers from Teaċ Daṁsa, MÁM overflows with circular energy. At a gathering where music casts a spell, dancers swirl, swoon and surrender in..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
