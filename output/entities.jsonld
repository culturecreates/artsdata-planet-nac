    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "William Prince | Further From the Country Tour with Boy Golden |  Fri, Mar 20, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39870/websize-2__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The distance travelled on William Prince’s new album, Further From the Country, is generational, aspirational, and metaphysical. Expansive and declarative, Further From the Country is the work of an artist who meets the challenge of putting incisive and enduring words to this age of uncertainty. William Prince’s perspective - a songwriter who carries great legacies of family and songcraft forward - is singular and significant. Further From the Country, his fifth LP, is an extraordinary work of observation, reflection and..."
      }
    ],
