    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Bruce Cockburn |  Fri, Oct 16, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40662/dsc05192-edit-2025-daniel-keebler__large.jpeg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Bruce Cockburn has enjoyed an illustrious career shaped by politics, spirituality, and musical diversity. His remarkable journey has seen him embrace folk, jazz, rock, and worldbeat styles while earning high praise as a prolific, inspired songwriter and accomplished guitarist. He remains deeply respected for his activism and humanist song lyrics that thread throughout his career. On all his albums, Cockburn has deftly captured the joy, pain, fear, and faith of human experience in song.\n\nBruce Cockburn has won 13 JUNO Awards, been inducted into the Canadian..."
      }
    ],
