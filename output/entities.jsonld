    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "GANNA  | with DIVKA |  Thu, Jun 11, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40597/untitled_design_(3)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Ukrainian-born, Berlin-based singer and composer GANNA (Ganna Gryniva) blends Ukrainian folk traditions, jazz-tinged arrangements, electronic soundscapes, and live looping in her solo project. Her acclaimed album UTOPIA combines ancestral melodies, ritual songs, and field recordings from Ukrainian villages with modern production, exploring themes of resilience, matriarchy, and belonging.  \n\nGANNA has performed at major European festivals including Jazzahead, WOMEX, and Reeperbahn, and toured extensively in Australia at Sydney Festival and WOMAdelaide. She describes her music as “improvised electro-folk with solo parts… a..."
      }
    ],
