      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Diyet and the Love Soldiers |  Thu, Mar 12, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40070/pheonix_pagliacci_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Connected by land, transformed by language, her songs are natural and genuine, a reminder to listen to the world around us.  \n\nAs long as she can remember, Diyet has been drawn to music and words as the easiest way for a shy kid to express herself. This led to a degree in music performance and a short career in publishing before she realized that home was calling her back. On returning home, she began writing more seriously from a more personal place. The result of..."
      }
    ],
