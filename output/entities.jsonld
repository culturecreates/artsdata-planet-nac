    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Marianne Trudel | plays Antônio Carlos Jobim |  Thu, Nov 26, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41623/trudel_ma.9742_copie__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Dive into the heart of Brazil and let yourself float away in the waves! It’s a real thrill for pianist and composer Marianne Trudel to revisit some of the greatest compositions in the Brazilian canon. As part of a truly elegant trio with Étienne Lafrance (double bass) and Sacha Daoud (drums and percussion), Trudel brings a delicate and sensual sound to the stage, in this one-of-a-kind celebration of Brazil. Passion, heat, intimacy and an incredible musicality await at a concert..."
      }
    ],
