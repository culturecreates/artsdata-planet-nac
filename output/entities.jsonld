    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Logan Staats |  Sat, Oct 3, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41653/rounded_corner_design-2__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": " Hailing from Six Nations of the Grand River, and fresh from his triumphant performance at the Los Angeles Kia Forum in front of 18,000 screaming fans for Life is a Carnival: A Musical Celebration of Robbie Robertson, Mohawk artist Logan Staats continues to prove his performance and songwriting ability. Recent highlights include a Juno Award nomination for his album A Light in the Attic, receiving the TD SOCAN Indigenous Songwriter Award, earning a Native American Music Award win in the..."
      }
    ],
