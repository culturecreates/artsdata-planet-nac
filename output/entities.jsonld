    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Satellite Birdhouse | Jukebox Lunch Concerts |  Thu, Jun 11, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41095/satellite_birdhouse__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Get ready for a Jukebox performance featuring Satellite Birdhouse, one of the 2026 Capital Music Awards Group of the Year nominees.\n\nInfectious, playful music that creates space for fun, longing, and connection is at the core of everything Satellite Birdhouse does. Stacy DuBois and Troy Huizinga’s songwriting combines story-driven lyrics with intricate melodic harmonies, landing them wide acclaim, frequent airplay, a Capital Music Award and, more importantly, a place in the lives of listeners.\n\nAs music and life partners, the folk rock..."
      }
    ],
