    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Echoes of the Opera | Great Performers Series / Ensemble Studio of the Canadian Opera Company |  Wed, Nov 18, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40674/metaadtemplate_5__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A focused evening of operatic discovery.\nA showcase of emerging talent and repertoire highlights.\n\nEchoes of the Opera features the exceptional young artists of the Canadian Opera Company Ensemble Studio in a thoughtfully curated piano-vocal program of beloved operatic arias and ensembles. As Canada's premier artist development program for emerging opera professionals, the COC Ensemble Studio has launched the careers of many of the country's leading singers, providing exceptional mentorship and performance opportunities at a pivotal stage in their artistic development.\n\nThis event..."
      }
    ],
