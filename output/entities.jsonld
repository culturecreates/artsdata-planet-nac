    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "This deeply personal show sits at the intersection of faith and art&mdash; a whimsical, funny, and heartfelt tribute from a Canadian theatre icon to his father, his passion, and the Korean-Canadian communities."
      }
