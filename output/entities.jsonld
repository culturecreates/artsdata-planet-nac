    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Handel's Messiah | Dec 15 - 16, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40408/copie_de_8130_nac_pops_handels-messiah_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "One of Ottawa’s most beloved holiday traditions returns to Southam Hall: Handel’s Messiah, with its ecstatic “Hallelujah” Chorus. So gather your closest friends and loved ones for an evening of music and celebration that’s certain to kindle the warmth and spirit of the holiday season!\n\nEvoking the theatrical splendour that has made Messiah a favourite of audiences around the world for nearly 300 years, the NAC Orchestra shares the stage with local choirs and a quartet of astounding soloists for Handel’s..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
