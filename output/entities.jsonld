    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us on Mondays for story time with Luana. Delight in tales that will sweep you away on journeys through magical worlds where you will meet enchanting characters. All accompanied by crafts and games. \n\nThis event occurs in French only. It’s an excellent opportunity for bilingual and francophone families alike!\n\nAbout Luana:\n\nLuana was born out of stardust and is here to teach all of us—big and small—how to ride the waves of our emotions! Luana’s stories and cast of characters take kids on a..."
      }
    ],
