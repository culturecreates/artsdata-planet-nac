    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Che_nous | D-Track, Dumis9ne, and Quest |  Sat, Nov 7, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41601/che_nous-upsized__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Che_nous, accompanied by Jean‑François Tremblay on piano and Eazy El Dee on the turntables, delivers an acoustic set with reggae inflections. At once organic and stripped down, the music and lyrics are given room to breathe. The group has made a name for itself with warm, socially conscious songs and catchy beats that captivate audiences and get them grooving. \n\nFounded in 2025, Che_nous blends hip-hop, reggae and world music. The project brings together D-Track (Gatineau) and Dumis9ne I (Malawi) on vocals,..."
      }
    ],
