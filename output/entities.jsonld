      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Rum Ragged  | The Feeling of Free |  Wed, Jul 15, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40947/rum_ragged_2_(credit__jeff_fasano)_(5)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to recharge at midday! \n\nFormed by Aaron Collis and Mark Manning, Rum Ragged takes a bold approach to the distinct folk music of their home, the Eastern Canadian island of Newfoundland and Labrador. Boasting bouzouki, fiddle, bodhran, banjo, guitar and button accordion, these new champions of East Coast music enliven and enlighten audiences with..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
