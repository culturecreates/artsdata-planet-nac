    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "A Night of Original Music by The Phoenix Big Band |  In support of the Ottawa Food Bank |  Wed, Apr 8, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40468/phoenix-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join The Phoenix Big Band at the NAC’s Fourth Stage in support of the Ottawa Food Bank for a joyful evening of original tunes that will make you want to get up and dance.\n\nBig sound with a big personality! The Phoenix Big Band’s all-original music blends elements of blues, jazz, funk, rock, Latin, and reggae into a toe-tapping celebration. The eight-piece band, featuring its dynamic horn section, was founded in 2009 and regularly lights up the Atomic Rooster on Bank..."
      }
    ],
