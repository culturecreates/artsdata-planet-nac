    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Zachary Lucky is an award-nominated Canadian songwriter celebrated for his timeless blend of folk, country, and roots music. Hailing from the prairie province of Saskatchewan, Lucky crafts songs steeped in place, memory, and the quiet resilience of everyday life. His warm baritone voice and evocative storytelling have drawn comparisons to Gordon Lightfoot and Kris Kristofferson, while his authenticity and dedication have earned him a loyal following across Canada and the world over. \n\nThe grandson of Canadian country music pioneer Smilin’ Johnnie..."
      }
    ],
