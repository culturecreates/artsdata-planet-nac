    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Daby Touré |  Sat, May 30, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40598/pna250711002-1152x648-fr-68264ed3__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The gifted Mauritanian Senegalese Daby Touré takes a fresh look at Africa. A true citizen of the world who refuses to be confined to traditional music, Daby Touré gives free rein to his taste for pop, folk, soul, reggae, jazz and blues. \n\nDaby Touré shapes a catchy, poetic musical landscape. Unclassifiable and universal. Being an African musician does not mean playing the kora or djembe in the pious respect of traditions. For decades now, from Dakar to Johannesburg, we have embraced global modernity and opened our ears wide to world..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
