      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Pre-show Chat: Rose | with Tomson Highway and Kevin Loring  |  Wed, Apr 1, 2026, 6:15 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40527/tomson-highway_credit_sean-howard__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for a conversation with Cree playwright and composer Tomson Highway and actor, director, and NAC Indigenous Theatre Artistic Director Kevin Loring.\n\nBorn in a snowbank on the Manitoba/Nunavut border, Tomson Highway is an Officer of the Order of Canada whose plays, novels, and music have reached audiences across six continents. One of the most influential voices in Indigenous storytelling, his work continues to resonate on stages around the world.\n\nTickets for Rose are not required to enjoy this free pre-show..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
