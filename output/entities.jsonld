    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dance at Zibi – Afro-Caribbean with SoulRhythms  |  Thu, Jun 18, 2026, 7:00 pm | Head Street Square – Zibi"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41081/soulrhythms01__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us at Zibi for a soul-inspiring dance session that will connect your mind, body, and spirit to the infectious celebratory rhythms of Africa and the Caribbean. From traditional to modern Afro-Caribbean folklore-based movement, Suzan Richards from SoulRhythms will lead you through an energizing 1-hour group class designed for all levels. \n\nDance at Zibi event series \n\nDance at Zibi is back for another season of rhythm, movement, and community. \n\nIn partnership with the Dream Community Foundation and the National Arts Centre, the 2026 edition kicks off on May..."
      }
    ],
