    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mozart, Korngold & Bryan Cheng | with the NAC Orchestra | May 6 - 7, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38416/6__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tMozart spent most of his life composing symphonies. He completed his first symphony at the age of eight and the “Jupiter” Symphony 24 years later.\n\tCanadian cellist Bryan Cheng returns to Southam Hall to perform not one, but two mesmerizing works for solo cello and orchestra.\n\tErich Wolfgang Korngold originally composed his Cello Concerto for a pivotal scene in the 1946 movie Deception, a film noir starring Bette Davis.\n\n\nIn one of his signature floods of inspiration, Wolfgang Amadeus Mozart composed his..."
      }
    ],
