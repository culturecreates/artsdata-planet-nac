    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Ostara Project  |  Sat, Jun 27, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40351/ostara_web__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Ostara Project, led by award-winning bassist Jodi Proznick, showcases the strength and creativity of Canadian women in jazz. Ostara artists are top-tier musicians, composers and bandleaders who reflect the geographical, cultural and creative diversity of Canada’s musical landscape. Guest vocalists are invited to join the instrumental group on a per-project basis. The Ostara Project’s self-titled debut album was nominated for a JUNO award in 2023. For the past two years, the group has been working on The Ancestors’ Project,..."
      }
    ],
