    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dance at Zibi – Bollywood with ArohaFest  |  Thu, May 21, 2026, 7:00 pm | Head Street Square – Zibi"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41079/bollywood_-_arohafest_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "On May 21, join the dancers of ArohaFest to discover the beauty and dynamism of Bollywood Dance! Learn basic choreography and groove to the rhythms of India with these trained performers who will leave you jumping for joy!\n\nDance at Zibi event series \n\nDance at Zibi is back for another season of rhythm, movement, and community. \n\nIn partnership with the Dream Community Foundation and the National Arts Centre, the 2026 edition kicks off on May 21 and runs monthly through August 20, featuring a..."
      }
    ],
