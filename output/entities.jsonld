    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mikhail Laxton |  Sat, Dec 5, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41635/rounded_corner_design_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Mikhail Laxton brings a soulful, feel-good vibe to honest songs about real life. With tracks like “Dirty,” “I Like The Way,” and “Something’s Gonna Give,” he blends nostalgic, roots-soul with singer-songwriter storytelling, diving into faith, love, and holding on when life gets tough. His music feels like a deep breath and a heart-to-heart, all wrapped in warm grooves and good energy. His brand-new EP, As Is, came out in late February 2026."
      }
    ],
