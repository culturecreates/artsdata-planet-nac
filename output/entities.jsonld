    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "At a time when the news is glorifying the triumph of billionaire despots, Robert Lepage tackles the famous Scottish tragedy, which addresses overwhelming paranoia, political conspiracy and the bloody thirst for power. Coincidence? The medieval..."
      }
