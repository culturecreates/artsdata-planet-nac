      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Flávia Nascimento and Tio Chorinho | The Feeling of Free |  Wed, Jul 22, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40945/2021-tiochorinho-flavia-03-credit-zahrasalecki__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Texto em português após o inglês \n\nEnjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to recharge halfway through your workday!  \n\nFlávia Nascimento and Tio Chorinho deliver a vibrant, high-energy performance blending Brazilian choro, samba, forró, and original compositions. Audiences can expect virtuoso musicianship, soulful vocals, dynamic rhythms, and playful improvisation. Flávia’s infectious stage presence brings audiences into the performance, often interacting and dancing..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
