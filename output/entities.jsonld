    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "An Evening with David Sedaris | Bestselling Author & Humorist  |  Sun, Sep 27, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
