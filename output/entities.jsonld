    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41802/main_image_horizontal_barbatuquescreYdit_photo_joseY_de_holanda_thaissa_duart__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Experience the richness and diversity of Brazilian music through the Brazilian Grooves Concert Series, featuring outstanding local artists, celebrated Canadian performers, and special guests arriving directly from Brazil. From obscure underground discoveries to internationally acclaimed, world-renowned artists, the series showcases the many sounds of Brazil—from samba and pagode to contemporary, vocal, and instrumental music—creating unique cultural connections through live performance in Ottawa.\n\nIn this intimate format, the co-founders of the world-renowned Brazilian group Barbatuques — Lu Horta, Helô Ribeiro, and Mariah..."
      }
    ],
