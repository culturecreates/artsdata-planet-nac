    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-11-26T21:30:00-05:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The Comeback: By Trish Cooper and Sam Vint"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "When Adam and Jesse&rsquo;s surprise pregnancy brings their M&eacute;tis and settler families closer together, long-buried tensions bubble to the surface. The Comeback, written by real-life married couple Trish Cooper and Sam Vint, is a funny and deeply personal look at what happens when families from different backgrounds collide. Join Adam and Jesse as they learn how to communicate, set boundaries, and enjoy chaotic family gatherings.&nbsp;"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/40386"
      }
    ],
    "http://schema.org/image": [
      {
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40386/the-comeback-concept-final_web__large.jpg"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g793040"
      },
      {
        "@id": "http://kg.artsdata.ca/resource/K14-29"
      }
    ],
