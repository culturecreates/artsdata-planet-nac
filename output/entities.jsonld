    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Bobby Previte's Pocket Orchestra |  Fri, Jun 26, 2026, 7:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40657/ojf_2026_showpass_1200x600_bobby_previte__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Bobby Previte is a composer and performer whose work explores the nexus between notated and improvised music. Previte is the recipient of the 2015 Greenfield Prize for Music and a Guggenheim Fellowship in 2012, as well as multiple awards for composition from the NEA, NYFA, and NYSCA. Mr. Previte has been an artist-in-residence at the Rockefeller Foundation in Bellagio, Italy, Civitella Ranieri, The Montalvo Arts Center, The Hermitage Artist Retreat, and nine times at the MacDowell Colony. Masterclasses include Princeton..."
      }
    ],
