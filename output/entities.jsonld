    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "daltonists |  Fri, Jun 26, 2026, 6:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40354/4_1768330071_copy_of_daltonists_promo_photo_by_alicja_nowicka_hi_resolution__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "daltonists is an experimental leftfield jam trio whose name references colour blindness, using this concept as a creative inspiration. Blending contemporary jazz, Afrobeat, dub, African, and club music, they have quickly made a mark on the scene since forming in June 2021, performing at major Polish festivals like Jazz Jantar, True Tone, and OFF Festival, and winning a special industry award at Crossroads Showcase Festival in Ostrava. Their debut mini album daltonists (2024) drew international attention online, while their second..."
      }
    ],
