      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Madeleine Peyroux |  Sat, Apr 11, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39332/madeleine_peyroux_076__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "“There is magic in live music that cannot be diminished,” says Madeleine Peyroux, “there is nothing more perfect than pure music, how it resonates in every corner of a room through every person - that’s what music is and that's what I'm here for.”  \n\nFor over three decades, jazz virtuoso Peyroux has travelled the world and graced the grandest concert halls to do just that - “share the magic of music with audiences, connect with people and uplift their spirits.” From entertaining passersby as a busker on the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
