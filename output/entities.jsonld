    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Tomoki Sanders |  Fri, Jun 26, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41120/copy_of_ojf_2026_showpass_1200x600_tomoki_sanders__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Born in New York City and raised musically in Japan, Tomoki Sanders (they/them) is a versatile multi-instrumentalist who began their journey with percussion and clarinet before mastering the tenor saxophone. After gaining early professional experience in the Kanto Region’s club scene and recording with psychedelic rock outfit Tengoku Batake Japon, Sanders moved back to the U.S. to attend Berklee College of Music. Since graduating in 2018 under the mentorship of jazz icons like Ralph Peterson Jr. and Tia Fuller, they..."
      }
    ],
