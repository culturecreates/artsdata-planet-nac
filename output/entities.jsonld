      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Empanadas Ilegales  | The Feeling of Free | Aug 4 - 6, 2026 | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40944/b12a6874_high_res__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "El español sigue al texto en inglés\n\nSpend your night with us under the stars! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer. \n\nFormed in 2017 through late-night jam sessions and rogue rooftop gigs, Empanadas Ilegales is a psychedelic tropical music collective made up of musicians with roots in Colombia, Ecuador, Argentina, and Canada. Their music is both homage and invention: cumbia meets surf..."
      }
    ],
