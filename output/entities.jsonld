      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Powwow Life-Drawing  |  Tue, Apr 14, 2026, 6:00 pm | Rossy Pavilion"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40645/img_0704__event_1440__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come join us for this two-hour life-drawing session where you can capture the dynamic beauty of powwow dances and their regalia on your own paper. Participants will bring their own material and work with art facilitators to create drawings that capture both the movement of the dancers and their regalia.\nSuitable intermediate to advanced artists. Bring your favourite materials along to participate. Some supplies will be offered to those that do not have any on hand.\nFree to participate! All attendees must..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
