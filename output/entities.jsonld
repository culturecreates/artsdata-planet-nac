    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sooshi Mango | The Home Made World Tour |  Fri, May 8, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40058/static_digital_3840x2160_sooshimango_2026_regional_nationalartscentre_0508_notext__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Sooshi Mango are one of Australia’s most successful and beloved comedy acts, created by brothers Joe and Carlo Salanitri and their close friend Andrew Manfre. What began just nine years ago as casual, car-ﬁlmed comedy clips quickly grew into a cultural phenomenon. Their relatable, character-driven humour—rooted in the experiences of immigrant families, has earned them record-breaking live shows, viral global reach, and a devoted audience across Australia and beyond.\n\nThe trio has achieved unprecedented success in live entertainment, becoming the only..."
      }
    ],
