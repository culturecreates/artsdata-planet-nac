      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Puuluup  |  Wed, Jul 15, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41309/puuluup-with_talharpas-34-photo_taavi_arus__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Musicians Ramo Teder and Marko Veisson direct the vibrations of the talharpa’s horsehair strings through effects, using alternative bowing and rhythm techniques. The mellow sighs of talharpa are paired with electronically amplified echoes, knocks, creaks and crackles. They create delightfully slinky songs about all possible random things around them. The lyrics combine many languages as well as Puuluup‘s made-up language, being mostly abstract and open to different interpretations. And they season their performances with unique choreography.  \n\nPuuluup has performed in around..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
