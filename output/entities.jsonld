    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kellylee Story & Song Series: Myra Melford |  Fri, Jun 26, 2026, 4:00 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
