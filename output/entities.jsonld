    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "La Famille Leblanc  | The Feeling of Free |  Wed, Aug 19, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41300/fg_7731r__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nThrough their music, La famille LeBlanc will take you to Poitou in France, where the Acadians arrived as refugees in the mid-18th century, then on to Louisiana and back to Canada's east coast for a feast of Acadian cuisine.   \n\nThis family plays a variety of..."
      }
    ],
