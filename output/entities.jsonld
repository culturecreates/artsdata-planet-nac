    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Céleste Lévis | Si elle |  Thu, Sep 24, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41582/rounded_corner_design_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Céleste Lévis is releasing her fifth album, Si elle, in winter 2026, and with it, she’s returning to the stage with a full band to round out her sound. Long lauded for her delicate ballads, Lévis makes a bold foray in her newest album into fully realized modern pop rock, proof of how she’s stepped into her own as an artist. \n\nThe story-telling on the album reflects her personal journey as a woman navigating the music industry, as a singer-songwriter rewriting..."
      }
    ],
