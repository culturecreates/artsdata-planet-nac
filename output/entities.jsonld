        "@value": "https://nac-cna.ca/en/event/41134"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Powwow Workout | with Amanda Fox |  Mon, Jun 29, 2026, 12:00 pm | Canal Lobby Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41134/powwowfitness1__large.jpeg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A powwow is a gathering to celebrate First Nations culture through dance, songs, food and crafts, and is open to all. The Pow Wow Workout is 45-minute high-intensity exercise program that will incorporate powwow dance steps from different styles of powwow dance and the sounds of contemporary and traditional powwow music into a simple, follow-along workout. Amanda will introduce Pow Wow’s history and cultural context throughout the program and respond to questions throughout the session."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
