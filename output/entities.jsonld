    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 Governor General's Performing Arts Awards |  Sat, Jun 6, 2026, 6:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40469/gg2026-nacweb_laureates__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for an exciting and elegant celebration of Canada’s highest distinction in the performing arts!\n\nNEW THIS YEAR! The spotlight hits Elgin Street. Join us at the NAC’s Elgin Street entrance as we roll out the red carpet and welcome this year’s laureates and performing artists in true show-stopping style. Come share in the excitement and celebration.  \n\nThe night gets going at 6:30 pm, with red carpet arrivals starting at 7 pm. At 8 pm, head into Southam Hall for a powerful lineup of unforgettable tribute performances celebrating..."
      }
    ],
