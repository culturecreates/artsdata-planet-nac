    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Grateful Dead's Legacy Manager & Archivist David Lemieux | In Conversation |  Sun, Jun 21, 2026, 4:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41119/copy_of_ojf_2026_showpass_1200x600_david_lemieux__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "David Lemieux has been the Grateful Dead's official audiovisual archivist since 1999, and their Legacy Manager since 2010. Over the past 27 years, Lemieux has produced scores of Grateful Dead CD and DVD releases, many of which have been certified Gold, Platinum, and Multi-Platinum by the RIAA®, as well as several Grammy® nominated boxed sets. He has produced 52 of the Grateful Dead’s World Record 66 Billboard Top 40 albums.\n\nLemieux was the Supervising Music Producer on the Martin Scorsese-produced career-spanning..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
