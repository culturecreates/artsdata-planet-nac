    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/38341"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Va falloir toujours toujours | Dance theatre | May 30 - 31, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38341/tfcna2526_vafalloirtoujourstoujours_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Jonathan and Nina are ready to take on the big challenge! These two dancers are pros, and they don’t mess around. But a third contestant comes hurtling onto the stage and starts complicating things a bit. Actually, a lot. When we try to be the PERFECT family, are we allowed to fumble? This pop-philosophy show blends dance and theatre to wreak havoc with our perfectionist ideals, sparking dishwasher confessions and thoughts about togetherness.\n\nA peculiar master of ceremonies has taken over..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
