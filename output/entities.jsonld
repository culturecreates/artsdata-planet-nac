    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Brittany Davis & Black Thunder |  Thu, Jun 25, 2026, 6:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40658/ojf_2026_showpass_1200x600_brittany_davis__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Black Thunder is the dazzling, fully improvised new offering from Seattle polymath Brittany Davis. Moving away from the drum machines and programmed keys of her previous album, Davis joins forces with bassist Evan Flory-Barnes and drummer D’Vonne Lewis for a raw, live session produced by Josh Evans.\n\nEvoking the soulful, pensive energy of Roberta Flack and Nina Simone, the album explores themes of ancestry, identity, and the nuances of perception. By"
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
