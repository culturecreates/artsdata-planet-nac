    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/41389"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Anónimas & Resilientes  | Experience bullerengue  |  Thu, Aug 20, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41389/anonimas_resilientes__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "From the deep countryside of Colombia’s Afro-descendant Maroon Caribbean emerges Anónimas & Resilientes, a collective of elder women singers safeguarding the ancestral legacy of bullerengue. This traditional music and dance style is rooted in rural communities near Montes de María, including Evitar, María la Baja, San José del Playón, Villa Gloria, and San Cristóbal del Trozo, in Colombia’s northwest region. The project brings together cantadoras who have preserved this tradition as a living practice of memory, resistance, and community healing. \n\nBullerengue..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
