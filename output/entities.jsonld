    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Pre-Show Chat with Hope Muir and Bobbi Jene Smith | Hosted by NAC Dance Executive Producer Caroline Ohrt |  Thu, Apr 23, 2026, 7:00 pm | Peter A. Herrndorf Place"
