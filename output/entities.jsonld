    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "ElderQueers (2SLGBTQIA+) Storytelling Workshop  | with Mary Ellen MacLean | Aug 24 - 28, 2026 | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
