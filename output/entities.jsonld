      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Myra Melford’s Fire & Water Quintet |  Sat, Jun 27, 2026, 7:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40345/myra_web__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Acclaimed pianist and composer Myra Melford brings together a powerhouse quintet of leading improvisers for a project that redefines the idea of a jazz “supergroup,” uniting artists she had previously collaborated with individually but never as an ensemble. Conceived during a 2019 residency at New York’s The Stone, the group’s chemistry was immediately evident, leading to the recording For the Love of Fire and Water, a suite inspired by the drawings of Cy Twombly and shaped by composed material, guided..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
