      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Postcards from Paris: Music from the Belle Époque  | The Feeling of Free |  Tue, Jul 14, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41386/dscf9191_curtis_perry__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nBe transported to turn-of-the-century Paris with flutist Stephanie Morin and pianist Sylvia Bruns in this elegant noon-hour recital. Inspired by the charm and vitality of the French capital at the dawn of the 20th century, the program captures a moment when the flute was..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
