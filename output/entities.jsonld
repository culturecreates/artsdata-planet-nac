    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kelly Bado |  Fri, Nov 13, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41719/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Born in the Ivory Coast, Kelly’s songwriting captures the beauty of the languages and rhythms she has encountered on her journey from Abidjan to Canada. Collaborating with GRAMMY and JUNO Award-winning producers Brian West and Chin Injeti, she merges traditional sounds with modern influences to create a distinctive musical landscape that sparks curiosity and invites audiences to explore traditional languages. She has shared the stage with artists such as Alessia Cara, Serena Ryder, and Walk Off the Earth, opened for Angelique Kidjo, and appeared on La Voix. Her latest..."
      }
    ],
