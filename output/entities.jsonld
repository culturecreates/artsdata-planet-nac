    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Eadsé |  Sat, Jun 13, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40824/untitled_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Eadsé is a Wendat singer-songwriter based in the Laurentians and a 2025–2026 Révélation Radio-Canada artist. Having amassed over 4 million streams, she presents Healer, her trilingual (French, English, Wendat) debut album, which blends pop-soul with themes of healing, resilience, and surrender. This show marks a new step in her artistic development, offering a moving and luminous musical experience.\n\nEadsé is releasing her very first album, accompanied by a bold and moving new live show. Her name, meaning “my good friend” in..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
