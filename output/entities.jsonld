    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "uOttawa at the NAC | Student Chamber Music Ensembles |  Mon, Mar 23, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40764/1440x810_fourth_3-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The NAC and the uOttawa School of Music have a long-standing relationship. Among other events, the NAC hosts uOttawa School of Music students in chamber recitals offered in the NAC’s Fourth Stage.\n\nThis series of three concerts showcases students in the uOttawa School of Music who represent excellence in the performance sector. Nominated by their professors, students from a variety of instrument areas are selected to perform solo recitals at the National Arts Centre, and one concert of the series is programmed..."
      }
    ],
