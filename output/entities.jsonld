      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Jaeden Izik-Dzurko Plays Rachmaninoff | & Appalachian Spring with the NAC Orchestra | Mar 18 - 19, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38410/17__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tBritish Columbia–born pianist Jaeden Izik-Dzurko made his orchestral debut at age 14!\n\tSergei Rachmaninoff’s final concerto for piano and orchestra is so difficult that the pianist for whom it was written never dared to perform it!\n\tAaron Copland’s Appalachian Spring portrays rural life in 19th-century America with music of soaring lyricism and foot-stomping dances.\n\n\nSergei Rachmaninoff’s Third Piano Concerto is adored by music lovers—and feared by pianists—for its marriage of technical fireworks and achingly romantic melodies. From the tolling of..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
