    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Les Violons du Roy with Johannes Moser | Great Performers Series |  Sun, Mar 8, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38399/metaadtemplate_1_(4)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tLes Violons du Roy heads west to showcase the captivating music-making that has made the group a fixture of cultural life in Quebec City and Montreal.\n\tTwo works evoke the wild adventures of Spanish literary hero Don Quixote and his witty sidekick, Sancho Panza.\n\tBeethoven’s String Quartet No. 11 finds new life on the concert stage in Gustav Mahler’s lushly romantic arrangement for string orchestra.\n\n\nThe members of Les Violons du Roy and Music Director Jonathan Cohen bring their boundless energy..."
      }
    ],
