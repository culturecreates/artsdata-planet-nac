    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Great Gatsby | Sep 8 - 13, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40616/8.-gatsby-na-tour-company_-photo-by-evan-zimmerman-for-murphymade-1000x667__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The party’s roaring in Ottawa!\n\nTHE GREAT GATSBY is a “Broadway extravaganza that explodes with life and energy” (Entertainment Weekly). Based on the classic American novel by F. Scott Fitzgerald, the Tony Award®-winning new musical is an unforgettable journey of love, wealth and tragedy that brings the Roaring Twenties to life on stage.\n\nDirected by Marc Bruni (Beautiful: The Carole King Musical), this story of extravagance and longing features choreography by Dominique Kelley (So You Think You Can Dance), a book by Kait Kerrigan (The Mad Ones) and..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
