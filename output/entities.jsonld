    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Murray & Peter proudly present the return of “WAR On The Catwalk” featuring contestants who appeared on the Emmy Award-winning television show, RuPaul’s Drag Race on MTV and Canada’s Drag Race on Crave TV. Get ready for your favourite drag queens performing live on stage! Hosted by Alyssa Edwards (winner of RuPaul’s Drag Race Global All Stars 2024), the Canadian tour includes performances by …… Jewels Sparkles, Suzie Toot and Lexi from Drag Race Season 17, plus Bosco, Lydia B...."
      }
    ],
