        "@value": "The Great Rhythmobile Adventure: Kinderconcerts Series"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "This theatrical performance features percussionists creating different rhythms using all sorts of everyday objects.&#8239;This makes for extraordinary choreography involving balls, rackets, garbage cans, and other unexpected items.&#8239;&nbsp;"
      }
