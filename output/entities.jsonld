    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "WolfGANG Sessions #28 | A Wild Night of Chamber Music |  Sat, Mar 21, 2026, 9:00 pm | Online"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40579/8789_nac_wolfgang28_eggplant__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "WolfGANG Sessions at Club SAW is a night of music that is sure to entertain. Grab your adventurous friends and take them out for a wild night of chamber music with your favourite musicians from the NAC Orchestra.\n\nHaving trouble connecting to the livestream?Check out at our Frequently Asked Questions section!"
      }
    ],
