    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Begonia | The Fantasy Life Tour with Cartel Madras |  Thu, Oct 8, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40783/untitled_design_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Begonia is your best friend. She’s the whimsical fairy on your shoulder, making you feel all at once comfortable to be yourself while simultaneously making you think what the heck is this fairy doing here, and what is she wearing?  \n\nBegonia (Alexa Dirks) is a Winnipeg-Born musician and entertainer. Her bold sound and style, combined with an intimate connection with her audience, invite you to feel everything more deeply, making you feel at once seen and a part of her world that is both brilliantly vibrant and..."
      }
    ],
