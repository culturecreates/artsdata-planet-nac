    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "For over twenty years, Alain Bédard has enjoyed a prolific career with his Auguste Quartet, touring the four corners of the globe. Remaining faithful to his original compositions, the ensemble has performed in dozens of countries across four continents, presenting hundreds of concerts throughout Asia, Europe, Russia, Africa, and North America — including Mexico and the United States — and especially in Canada and his native Quebec.\n\nWith six albums to their name — Auguste, Sphère Réflexion, Bluesy Lunedi (finalist at..."
      }
    ],
