  {
    "@id": "https://nac-cna.ca/en/event/40372#2026-09-25T20:00:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/DanceEvent"
    ],
    "http://schema.org/startDate": [
