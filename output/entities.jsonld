  {
    "@id": "https://nac-cna.ca/en/event/40409",
    "http://ogp.me/ns/fb#app_id": [
      {
        "@language": "en-ca",
        "@value": "123254964370141"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/40409"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Music for a Sunday Afternoon: Fall Edition | with John Storgårds and members of the NAC Orchestra |  Sun, Nov 8, 2026, 3:30 pm | Carleton Dominion-Chalmers Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40409/9169_nac_naco_26_27_batch1_12__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A few things to know ... \n\n\n\tSink into some seriously relaxing weekend vibes as you experience intimate performances from some of your favourite NACO musicians. \n\tSurrounded by the acoustic and architectural marvels of the Carleton Dominion-Chalmers Centre, you’ll feast on a program of music for string orchestra spanning three centuries. \n\tWatch out for Music Director John Storgårds on the stage—but rather than conducting the program, he’ll be playing violin! \n\n\nTravel across time as Music Director John Storgårds and the NAC Orchestra’s string players explore music spanning three centuries—from dance-inspired works of the Baroque..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
