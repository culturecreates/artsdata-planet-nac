      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Just Prince | and Friends |  Fri, May 15, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40593/just_prince_-_2026_promo_pic__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Toronto-based singer-songwriter Just Prince is known for seamlessly blending Western and Eastern sounds into a harmonious tapestry. With a captivating style that defies genre constraints, his music weaves elements of folk, rock, blues, and Hindustani classical music into a mesmerising experience. Just Prince's evocative compositions take listeners on a sonic journey, transcending cultural boundaries and resonating with the soul. Through his innovative approach, he crafts a musical landscape that bridges worlds with the intention of genuine songwriting and experimental expression. \n\nJust Prince‘s album Ocean is set for release..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
