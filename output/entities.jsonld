    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Class on Stage with The National Ballet of Canada |  Sat, Apr 25, 2026, 1:30 pm"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40886/2022_18_(300)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Watch dancers take company class\n\nClass on Stage is a unique opportunity to see the dancers of The National Ballet of Canada in the daily ritual of company class, elevated to an on-stage experience that showcases their amazing physicality, commitment, and collegiality."
      }
    ],
