    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Beautiful Scars | By Tom Wilson and Shaun Smyth | Sep 10 - 19, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40384/beautiful-scars-artwork-final__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "THE ELECTRIFYING CANADIAN ROCK MUSICAL REVEALING A LONG-BURIED FAMILY SECRET. \n\nBeautiful Scars tells the story of Tom Wilson, of the band Blackie and the Rodeo Kings, and his search for truth and identity when a long-held family secret comes to light. The musical, inspired by Wilson's bestselling memoir of the same name, follows his journey from Hamilton's east Mountain to the Kanien'kehá:ka (Mohawk) community of Kahnawake. Join a talented cast, starring Sheldon Elter as Tom Wilson, as they reveal long-hidden secrets and..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
