      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Empanadas Ilegales  | The Feeling of Free |  Wed, Aug 5, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40943/b12a6874_high_res__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to recharge over a lunch break! \n\nFormed in 2017 through late-night jam sessions and rogue rooftop gigs, Empanadas Ilegales is a psychedelic tropical music collective made up of musicians with roots in Colombia, Ecuador, Argentina, and Canada. Their music is both homage and invention: cumbia meets surf rock, salsa runs through Persian melodies, and..."
      }
    ],
