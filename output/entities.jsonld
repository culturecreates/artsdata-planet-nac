    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Joe Farnsworth's Big Room Quartet |  Sat, Jun 20, 2026, 7:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40660/ojf_2026_showpass_1200x600_joe_farnsworth_s_big_room_quartet__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Joe Farnsworth is one of the most prolific jazz drummers of his generation, with a career spanning over 400 recordings and decades of performances at the world’s most iconic venues. A two-time Grammy nominee, Farnsworth has dedicated his life to mastering the jazz tradition to bridge the gap between its storied past and its vibrant future.\n\nRaised in a musical family and mentored by legends like Alan Dawson, Arthur Taylor, and Jimmy Lovelace, Joe moved to NYC in 1990. He quickly..."
      }
    ],
