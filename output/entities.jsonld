    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "David Suzuki&rsquo;s Playlist: With the NAC Orchestra, in association with Why Not Theatre"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A unique live musical evening curated and hosted by David Suzuki, connecting the works that inspired him with a powerful reflection on nature and our relationship with the living world."
      }
