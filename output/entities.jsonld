    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Rooted along the banks of the Kitchissippi (Gatineau, QC), Mia Kelly is an award-winning singer-songwriter, making her mark internationally with her distinctive blend of folk, rock, and blues. Carrying the power of the river she calls home, her voice winds and weaves stories, raw and breaking with emotion in English and French. \n\nHer newest record, Big Time Roller Coaster Feeling - produced by Connor Seidel (Charlotte Cardin, Half Moon Run, Donovan Woods), celebrates juicy, joyful moments of life and shines light..."
      }
    ],
