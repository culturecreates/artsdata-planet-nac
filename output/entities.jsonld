      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Beethoven, Britten, Bruch & Kerson Leong | With the NAC Orchestra | Oct 7 - 8, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40404/9169_nac_naco_26_27_batch1_13__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A few things to know ...\n\n\n\tWritten more than 130 years apart, a pair of symphonies by Beethoven and Britten make the heart race with crackling energy and radiant joy.\n\tAnd for those hungry to experience a work of profound emotion, Bruch’s Violin Concerto No. 1, performed by Ottawa’s own Kerson Leong, is a breathtaking exploration of love, longing, and hope.\n\n\nComposed at the height of the Romantic era, Max Bruch’s Violin Concerto No. 1 is celebrated for its soaring melodies, rich orchestration,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
