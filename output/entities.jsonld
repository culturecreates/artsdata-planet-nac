    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Rory Taillon | Jukebox Lunch Concerts |  Thu, May 21, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41075/rory_taillon_credit_ethan_mitchell__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Alternative indie folk singer Rory Taillon has been touring Canada for over a decade, performing on stages from coffee shops and living rooms to concert halls and festivals. He has shared stages with the likes of Stephen Fearing, Zeus, Jeff Martin of the Tea Party, Adrian Sutherland and Julian Taylor, to name a few. Since 2012, he has released two EPs and four albums, including the recent Now It’s Quiet (2024). \n\nRory was trained as a classical singer from a young age, and his years of study are evident in the power and control that he has over..."
      }
    ],
