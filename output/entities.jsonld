  {
    "@id": "https://nac-cna.ca/en/event/40241#2026-05-04T19:00:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/DanceEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-05-04T19:00:00-04:00"
