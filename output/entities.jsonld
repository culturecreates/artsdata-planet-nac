  {
    "@id": "https://nac-cna.ca/en/event/41304",
    "http://ogp.me/ns/fb#app_id": [
      {
        "@language": "en-ca",
        "@value": "123254964370141"
      }
    ],
    "http://ogp.me/ns#type": [
      {
        "@language": "en-ca",
        "@value": "article"
      }
    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/41304"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "OK Naledi  | The Feeling of Free |  Sat, Jul 11, 2026, 4:30 pm | Along the Rideau Canal"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41304/ok_naledi_photo__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "OK Naledi is a high-energy, Afro-Fusion music group based in Ottawa. \n\nRooted in Motswana heritage, OK Naledi weaves raw emotion and vibrant sounds into stories of heartbreak, love, queerness, family and adulthood. Their songwriting is deeply personal, shaped by the experience of living in a Western context while carrying the roots and rhythms of southern Africa. OK Naledi blends traditional sub-Saharan guitar lines, warm bassy grooves, and movement-inspiring beats to create a sound that’s both genre-defiant and soul-stirring. Their lyricism is..."
