    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "L&#039;Orestie: The iconic classical trilogy revisited by Alice Ronfard"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In the wake of her unforgettable Travers&eacute;e du si&egrave;cle, Alice Ronfard tackles the seminal text of Western theatre, if not of Western thought. Like an ambitious theatrical river, her adaptation flows from ancient Greece to the present day, carrying with it the timeless question of justice. Three tragedies, 33 performers: an epic journey through the centuries."
      }
    ],
