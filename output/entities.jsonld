    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Passion simple: An intimate tale of waiting"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Three theatrical stars sparkle in a rare alignment: a brilliant director (Brigitte Haentjens), a radiant actress (Julie Le Breton) and the Sun herself (writer Annie Ernaux). Ernaux dissects a heart consumed by passion in this autobiographical tale."
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/38337"
      }
