    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ray Chen in recital | Great Performers Series |  Sun, Oct 18, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
