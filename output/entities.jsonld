      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Mommy, le retour: Gore, rap and political musical satire"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "She may have died in a long-term care facility, but she comes back to life to wreak revenge! This reactionary mummy, sprung from the imagination of the mad scientist of theatre, Olivier Choini&egrave;re, leads a ceremony sung and rapped by neo-fascist zombies. A hilarious political satire with the feel of a musical horror story."
      }
    ],
    "http://schema.org/keywords": [
      {
        "@value": "Francophone"
      },
      {
        "@value": "Theatre"
      }
    ],
