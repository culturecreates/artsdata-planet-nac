      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Beaded Earring Workshop | with Stephanie Peltier |  Sat, May 2, 2026, 11:00 am | Atelier Shenkman Smith"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40887/beaded_earring_workshop_-_event_image_(1)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come join Stephanie Peltier of Deliaestelle Designs for this beaded earring workshop! \nYou will receive the popular Beginner Beading Kit that has everything to make a pair of beautiful beaded earrings, with a surprise bead colour inside! Included are instructions, beads, gems, threads, stud backings, and much more! In this 3-hour workshop, Stephanie will guide you through the earring making process where you can share your process and ask questions along the way.\nSuitable for beginner beaders and experienced beaders alike, ages..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
