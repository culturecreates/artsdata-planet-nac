    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Cranium Conference & Showcase 2026 | Day 2 |  Sat, May 9, 2026, 12:00 pm | National Arts Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41122/day_2_nac_1-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Cranium Arts Project is excited to announce the Cranium Conference and Showcase 2026. \n\nThe two-day music event will connect active industry professionals with musicians, artists and people making moves in the arts and entertainment business. The weekend will feature networking sessions, information panels with music professionals, masterclasses, and a showcase featuring some great emerging talent. \n\nSchedule: Saturday, May 9, 2026 \n\n12:00 – 12:45 pm: Creator Meet Up\n\nAtelier Shenkman Smith – FREE, no registration required  \nCalling all music creatives. Kick-start the day by tapping in, connecting..."
      }
    ],
