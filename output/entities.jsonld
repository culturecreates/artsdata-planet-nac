      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Comeback | By Trish Cooper and Sam Vint | Nov 26 - Dec 5, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40386/the-comeback-concept-final_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A co-production with The Citadel Theatre (Edmonton)\n\nA love story. With baggage.\n\nThe Comeback, written by real-life married couple Trish Cooper and Sam Vint, is a funny, honest, and nuanced look at what happens when families from different backgrounds collide. The play follows Adam, a Métis writer navigating identity and family history, and his settler wife, Jesse. When Adam and Jesse's surprise pregnancy brings their Métis and settler families closer together, long-buried tensions bubble to the surface.\n\nNot quite fact, not quite fiction,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
