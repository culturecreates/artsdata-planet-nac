    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Je comprends. Respect.: A theatrical hip-hop battle"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "An irresistible hybrid between an authentic hip hop battle and Etienne Lou&rsquo;s life story. The brilliant actor and dancer humorously and candidly reveals his chaotic youth. A thousand dollars, three judges, an entranced crowd, truth, lies&hellip; in a word, theatre&mdash;with lots of beat!"
      }
    ],
