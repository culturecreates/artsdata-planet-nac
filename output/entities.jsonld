      {
        "@language": "en-ca",
        "@value": "Bonnie Raitt | Live 2026 with Special Guest Maia Sharp |  Thu, Aug 13, 2026, 7:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
