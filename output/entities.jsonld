    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Capital Music Awards  | Ottawa Music Industry Coalition  |  Fri, Oct 9, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41535/dscf0160_curtis_perry_-_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for an unforgettable evening at the National Arts Centre and be part of the magic of music as we celebrate Ottawa’s finest.\n\nSince 2020, the Capital Music Awards (CMAs) have recognized outstanding achievements across Ottawa’s music industry—celebrating artists, educators, curators, venues, technicians, and the many professionals who bring our music ecosystem to life.\n\nProduced by the Ottawa Music Industry Coalition (OMIC), the CMAs have become the city’s largest annual music industry gathering, showcasing the depth, diversity, and excellence of talent..."
      }
    ],
