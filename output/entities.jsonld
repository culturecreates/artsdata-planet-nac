      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Turkwaz | The Feeling of Free |  Wed, Aug 12, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40975/turkwazpromo3__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nTurkwaz is a unique combination of four musicians, immersed in diverse traditions from mysterious Sufi devotional love songs, to rousing Thracian dance music. Each performer brings a special flavour to the group: Maryem Hassan Tollar draws on her Arabic language heritage; Jayne Brown and..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
