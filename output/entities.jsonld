    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41074/sophie__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Sophie Grenier, winner of the Breakthrough Artist award at the 2025 Gala Trille Or and nominated for Breakthrough Artist of the Year at the 2024 ADISQ Gala, is a Canadian singer-songwriter who captivates audiences with her cinematic pop sound.  \n\nWinner of La Voix season 9, she quickly made her mark on the Quebec and Francophone Canadian music scene with her EP Escape and her album À l’envers, which reached #1 in francophone album sales in Quebec.\n\nJukebox Lunch Concerts  \n\nEvery break deserves a..."
      }
    ],
