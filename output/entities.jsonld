    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Camions (fant&ocirc;mes de la libert&eacute;): An audio walking tour"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Breaking: Following the 2022 protests, we&rsquo;re hearing that the NAC is about to be INVADED BY TRUCKS again... tiny ones this time around! We&rsquo;re also learning that kids will be at the wheel, audiences will be wearing headphones and this intergenerational walkabout adventure will be a fun new look at the meaning of freedom."
      }
    ],
    "http://schema.org/url": [
