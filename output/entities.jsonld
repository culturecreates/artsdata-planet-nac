      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Carneiro, Mozart & Goodyear | with the NAC Orchestra | May 27 - 28, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38417/11__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "What to know about this concert:\n\n\n\tStewart Goodyear is both a pianist and composer—just like Mozart, whose Piano Concerto No. 23 Goodyear will bring to life on the Southam Hall stage. \n\tAfter her seismic performances of two Igor Stravinsky ballets with the NAC Orchestra, Joana Carneiro returns to conduct Felix Mendelssohn’s “Reformation” Symphony.\n\n\nA heartfelt work guided by the composer’s devout Protestant faith, Felix Mendelssohn’s “Reformation” Symphony commemorates the 300th anniversary of the Presentation of the Augsburg Confession, a pivotal event in the history..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
