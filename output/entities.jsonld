      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Los Vega  | The Feeling of Free |  Thu, Jul 9, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41293/los_vega__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "El español sigue al texto en inglés\n\nEnjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day!\n\nLos Vega is a traditional son jarocho group that has been dedicated to the performance, dissemination, and promotion of this musical genre for 20 years. Their music is characterized by the balance they achieve between their cultural roots..."
      }
    ],
