    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Cranium Showcase 2026 |  Sat, May 9, 2026, 7:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41084/88zeroo_craniumshowcase_day3_13__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Cranium Showcase brings you tomorrow’s stars today. The 2026 showcase will feature eight live music acts from Ottawa, Canada and around the world. Dive into the musical flavours of afrobeat, R&B, hip-hop, soul and more, as these budding stars provide a peek into the future of live music. \n\nProving once again that Ottawa is a vibrant city with a rich music and cultural landscape, the Cranium Showcase will present emerging talents who are poised for promising music careers. Known as a tastemaker and key professional..."
      }
    ],
