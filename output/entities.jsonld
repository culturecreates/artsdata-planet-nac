    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mani reçoit Robert Lepage | Pre-show talk |  Fri, Jun 5, 2026, 6:15 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41586/lepage1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "On Friday, June 5, starting at 6:15 p.m., the public is invited to the NAC’s Peter A. Herrndorf Place for the premiere of Macbeth to attend an interview with acclaimed director Robert Lepage, hosted by Mani Soleymanlou. Bar service will be available."
      }
    ],
