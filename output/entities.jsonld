  {
    "@id": "https://nac-cna.ca/en/event/40431#2026-10-31T11:00:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/TheaterEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-10-31T11:00:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-10-31T11:45:00-04:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "&Agrave; poils: Explosive, immersive stage experience you can dive straight into"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Don&rsquo;t miss this mind-blowing Unidentified Furry Object from France! To the sound of electric guitars, three rather tough-looking stage technicians begin to load in equipment and summon us to help them. Then a spectacular transformation takes place, revealing the gentle and colourful animal hidden behind each shaggy beast!"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/40431"
      }
    ],
