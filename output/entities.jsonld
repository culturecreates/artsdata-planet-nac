      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Capital Sessions with DJ Eazy EL Dee and Effect | Free community house dance practice |  Sun, Apr 19, 2026, 1:30 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40576/capital_sessions_april_2026__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Capital Sessions is back at the NAC for a Latin House Edition with DJ Eazy EL Dee and dancer Effect from Moov Ottawa! It's a free community house dance practice brought to you by Tangent and Rise Ashen.  \n\nIt's family and beginner-friendly. The DJ plays from 1:30 to 3:30 pm and the dancer leads two 30-minute workshops at 1:30 and 2:30 pm. You can just dance, learn or listen and vibe out - it's a beautiful space with amazing music! No experience..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
