      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "HYL | “Song rapper” |  Sat, Apr 18, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39307/celeste_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "HYL’s music falls somewhere between song and colourful electro-pop rap. His lyrics shape melodies reminiscent of Orelsan, Gaël Faye, or the infectious energy of Thérapie TAXI, striking a balance between carefree and aware. \n\nIn 2024, he released a second EP that reflects the influences that inspire his art. Produced at the La Tanière studio (Bigflo & Oli, among others), this new, assured vision transports us into stories and emotions we all seem to have experienced before. HYL will be at the NAC for one night..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
