    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Post-show Dance Party | Traditional music and dance with La Déferlance and Yaëlle Azoulay |  Fri, Sep 25, 2026, 9:30 pm | Canal Lobby"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41759/20221231-veillee-avant-veille-vma_1088_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "NAC Dance invites you to a traditional dance party in the Canal Foyer, designed to enhance your experience of the show MÁM by Irish choreographer Michael Keegan-Dolan (Teaċ Daṁsa). To the sound of traditional Quebec music performed live by the group La Déferlance, renowned caller Yaëlle Azoulay will guide you through some basic folk dance steps. Whether you’re already a fan or it’s your very first time, everyone is welcome to join this upbeat, informal gathering. You’ll be swinging your hips and tapping your feet in..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
