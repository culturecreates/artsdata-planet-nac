    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Great Canadian Comedy Caravan Tour | Benefit for Ronald McDonald House Ottawa |  Fri, Apr 24, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39802/2426_x1365_nac_comedy_caravan__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Great Canadian Comedy Caravan Tour is returning to the National Arts Centre for their 2nd annual benefit gala with Ronald McDonald House Ottawa on Friday April 24th.\n\nRick Currie (The Rick Mercer Report, Gemini Award Winner, multiple Canadian Screen Awards for writing in television, CBC’s Laugh Out Loud, CBC’s The Debater, CTV’s Comedy NOW, Just For Laughs, Winnipeg and Halifax Comedy Festivals) headlines this star-studded affair! \n\nRick has also appeared on the 2014 Canadian Country Music Awards and Canada 150 Celebrations from Parliament Hill,..."
      }
    ],
