      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mistral | Dans l’univers d’Astor  |  Sat, Mar 14, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39689/dans_lunivers_dastor-photo_officielle_26-27__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Dans l’univers d’Astor is a musical and narrative show that immerses the audience in the life, music, and inspirations of Astor Piazzolla, the Argentine composer and bandoneonist considered the greatest innovator of tango in the 20th century.\n\nFrom New York to Paris by way of Buenos Aires, Mistral presents an original portrait in which Piazzola’s works are interwoven with classical music, jazz, traditional tango, klezmer, and fascinating biographical anecdotes!\n\nBenjamin Deschamps: saxophone\nNadia Monczak: cello\nSébastien Pellerin: double bass\n​Hugo Larenas: guitar"
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
