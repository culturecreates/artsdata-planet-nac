    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Les Charbonniers de l'enfer | The F-I FI, N-I NI show |  Thu, Oct 1, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
