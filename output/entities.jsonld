    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "WolfGANG Sessions at Club SAW is a night of music that is sure to entertain. Grab your adventurous friends and take them out for a wild night of chamber music with your favourite musicians from the NAC Orchestra."
      }
