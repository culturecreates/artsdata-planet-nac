    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Josh Johnson's Comedy Band Camp | Jun 12 - 13, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40199/3840x2160__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Josh Johnson’s Comedy Band Camp is a stand up and live music experience that brings together all the community of being in one big band and all the nostalgia of summer camp. This is the camp experience Josh never had so he made it for you.\n\nWith over 10 million followers across social media, Josh Johnson was recently called “the funniest guy on the internet” by WIRED. He is an Emmy-nominated writer, stand-up comedian, actor, and NAACP award-winner from Louisiana by..."
      }
    ],
