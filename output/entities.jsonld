    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "The King James Bible Play: Written by Charlotte Corbeil-Coleman"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "All is not as it seems as a committee of religious scholars attempt to translate the Bible for King James I, navigating clashing egos, royal expectations, and &ndash; anachronistically &ndash; the nature of male loneliness."
      }
    ],
