      {
        "@language": "en-ca",
        "@value": "Ottawa Jazz Orchestra | Beyond the Cool | Apr 23, 2026  | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39363/diane_with_bass_and_drums__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Don't miss this sublime, one-night-only programme presented by the Ottawa Jazz Orchestra! Experience the sumptuous sound of our nonet, featuring unique pairings of alto and baritone saxophones, trumpet and trombone, and French horn and tuba, all anchored by a piano trio.\n\nWe'll kick things off with a complete performance of the celebrated"
      }
    ],
