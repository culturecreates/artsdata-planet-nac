    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "ElderQueers (2SLGBTQIA+) Storytelling Workshop in Halifax | with Mary Ellen MacLean | Jul 20 - 24, 2026 | Universalist Unitarian Community of Halifax"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41696/elderqueers_halifax_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Welcome to Elder Queer (2SLGBTQIA+) Storytelling with Mary Ellen MacLean\n\nThis workshop offers an opportunity to gather, deepen your community connections, and create stories with the support of each other and Mary Ellen’s guidance. The focus is on having fun, learning some new skills, and connecting with each other.  \n\nThis event is open to folks who have never written or told a story out loud before, as well as those who have. If you have attended one of Mary Ellen’s workshops before,..."
      }
    ],
