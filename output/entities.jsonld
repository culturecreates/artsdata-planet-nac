    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Gabi Hartmann |  Fri, Mar 13, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39865/web_resize_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Gabi Hartmann is a rising star on the current jazz scene, following in the footsteps of artists such as Norah Jones and Melody Gardot. The Parisian singer–songwriter has created a unique world where jazz, soul, and world music converge, and her gentle, melancholic voice transcends stylistic boundaries. \n\nGabi’s eponymous debut album, released in 2023, won over critics and audiences alike, surpassing 20 million streams and selling over 15,000  copies. She has performed at such major festivals as Jazz à Vienne, Les Francofolies, and the Montréal International Jazz Festival, and has collaborated with renowned jazz musicians, including Jesse Harris, Julian Lage, Laurent Bardainne, Éric Truffaz,..."
      }
    ],
