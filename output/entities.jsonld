      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Queen of Soul: A Tribute to Aretha Franklin | with the NAC Orchestra | Mar 12 - 14, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38428/cf_3multicolorkaftan__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tThis joyful, high-octane tribute to Aretha Franklin includes all your favourite songs from the Queen of Soul and the artists who inspired her. \n\tA star of stage and screen, Capathia Jenkins and her powerhouse voice will bring Franklin’s biggest hits to life in Southam Hall. \n\t“She was a singular talent,” Jenkins has said of Franklin. “It’s really an honour to stand on her shoulders and be able to do an evening-length tribute to her.” \n\n\nFeaturing Aretha Franklin’s biggest hits from..."
      }
    ],
