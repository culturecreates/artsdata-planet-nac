      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "After the Rain | Feb 25 - Mar 7, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38312/nac-et_after-the-rain_event-thumbnail-1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An NAC English Theatre Revival of the Tarragon Theatre / Musical Stage Company Co-production \n\nWhat if music had the power to heal what hurts the most?\n\nSuzie is struggling. Her parents are nagging her. And her personal life is flatlining. That is until a mature piano student fixated on mastering Erik Satie’s Gymnopedie No. 1. seeks her musical guidance and changes everything. Join Suzie as she tries to forge her own path while her preoccupied parents hover over her, struggling with the uncertainty..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
