      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Tout ce qu’il reste | Vías | Mar 13 - 14, 2026 | Carleton Dominion-Chalmers Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38372/_0001_viYas_tout_ce_qu_il_reste_credit_robin_pineda_gould__7527__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Poetry in movement\n\nWithin the soaring sanctuary of the Carleton Dominion-Chalmers Centre, choreographers Paco Ziel and Diana León (Vías) invite audiences to rediscover Franz Schubert's work from a fresh perspective. By playing on the intimate relationship between dance, music and poetry, the artists propose a performance that spills out into space, nourished by the emotional complexity characteristic of Schubert’s lieder. Freely intertwining with the song and sounds of baritone Olivier Bergeron and pianist Chloé Dumoulin, Ziel and León imagine an immersive,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
