    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Je comprends. Respect.  | A theatrical hip-hop battle | Dec 3 - 5, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40436/tfcna2627_jecomprends_1920x1080__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Go ahead and make noise during this irresistible hybrid show, part hip hop battle and part captivating autobiographical tale by gifted actor and dancer Etienne Lou. Holding nothing back, he describes his chaotic journey from youth to breaking into the world of urban dance. A thousand-dollar prize, three judges, a DJ, an entranced crowd, truth, lies… in a word, theatre, but with lots—and we mean lots—of beat!\n\nTwo battles take place on stage. First, an hour before showtime, street dance masters..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
