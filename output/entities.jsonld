    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "AKEEM OH presents FEAR OF MISSING OUT at the National Arts Centre — the highly anticipated debut EP from the self-proclaimed soft.boi.indie.pop artist, premiering in the city where it all began. Writing from the edge of the moment, AKEEM OH creates music where romance meets reflection, vulnerability feels cinematic, and nostalgia hums beneath neon light.\n\nBorn in Philadelphia and raised in Mattawa, his identity is shaped by contrast. An African-American artist adopted by white and Indigenous French-Canadian parents, AKEEM OH brings..."
      }
    ],
