    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Te Tangi a Te T&#363;&#299;: By Tainui Tukiwaho and Amber Curreen"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A visually stunning cirque-theatre piece from Aotearoa/New Zealand, Te Tangi a Te T&#363;&#299; follows Piri, a boy caught between two supernatural forces, each seeking to shape his fate. Performed in Te Reo M&#257;ori, this powerful tale explores love, hope and legacy."
      }
    ],
    "http://schema.org/url": [
