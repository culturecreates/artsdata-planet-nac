    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ottawa Jazz Orchestra | Nutcracker Double | Dec 19, 2026  | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41710/nutcracker_double__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Ring in the holiday season with the Ottawa Jazz Orchestra and a festive, swinging celebration of Tchaikovsky’s beloved winter masterpiece. This unique concert offers a fascinating dual-perspective on the iconic ballet, featuring two legendary big band interpretations performed back-to-back. Experience the cool, brassy, West Coast jazz brilliance of Shorty Rogers' celebrated arrangement, perfectly contrasted with the warm, nostalgic, and unmistakable swing of the Glenn Miller Orchestra’s version. To complete this joyful evening, the orchestra will round out the program with..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
