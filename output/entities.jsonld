    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 Capital Music Awards Nominee | Jukebox Lunch Concerts |  Thu, Jun 11, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41095/jb_placeholder04__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Who's hitting the stage? Get ready for a Jukebox performance featuring a 2026 Capital Music Awards nominee, to be revealed soon. Join us for a lunchtime concert celebrating some of the region's most exciting talent!  \n\nCapital Music Awards \n\nThe Capital Music Awards celebrate and recognize outstanding artists, creators, and industry professionals across the National Capital Region. This year’s ceremony will take place on October 9, 2026, at 8 pm, in Southam Hall at the National Arts Centre. \n\nJukebox Lunch Concerts\n\nEvery break deserves a great soundtrack!..."
      }
    ],
