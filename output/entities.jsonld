  {
    "@id": "https://nac-cna.ca/en/event/40384#2026-09-10T19:30:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/TheaterEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-09-10T19:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-09-10T21:30:00-04:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Beautiful Scars: By Tom Wilson and Shaun Smyth"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Beautiful Scars tells the story of Tom Wilson (Blackie and the Rodeo Kings) and his search for truth and identity when a long-held family secret comes to light. This musical, inspired by Wilson&rsquo;s bestselling memoir of the same name, follows his journey from Hamilton&rsquo;s East Mountain to the Kanien&rsquo;keh&aacute;:ka (Mohawk) community of Kahnawake and every revelation in-between. Come experience a production brimming with energy, powerful tunes, and Wilson&rsquo;s signature style, brought to life by a talented cast."
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/40384"
      }
    ],
    "http://schema.org/image": [
      {
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40384/beautiful-scars-artwork-final__large.jpg"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g577300"
      },
      {
        "@id": "http://kg.artsdata.ca/resource/K14-29"
      }
    ],
    "http://schema.org/workPerformed": [
      {
