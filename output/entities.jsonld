    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Resonance: Korean Cultural Centre 10th Anniversary Concert | Dosi and Maria Kim |  Sat, Jul 18, 2026, 7:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41244/kcc_10th_concert_06.08_nac__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Lineup Update\n\nWe regret to inform audiences that the vocalist of Gonia is unable to participate in this performance due to an unexpected medical issue and will not be travelling to Canada.\n\nThe concert will proceed as scheduled, featuring Dosi and Maria Kim, who will showcase the richness and beauty of traditional Korean music.\n\nWe thank audiences for their understanding and join the artists and organizers in wishing the performer a smooth recovery.\n\nTo help us share this special celebration of Korean culture with..."
      }
    ],
