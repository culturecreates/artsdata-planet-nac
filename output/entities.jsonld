    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Neige sur Abidjan: Autofiction between here and Africa"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In this touching and intimate work of autofiction, Iannicko N&rsquo;Doua takes us on a coming-of-age journey across years and continents, guided by a charismatic griot with a thousand faces. The playwright and performer believes he is merely searching for his father, but he discovers a whole country where part of his family and heritage are flourishing."
      }
    ],
