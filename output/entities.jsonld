      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Primary Colours  | The Feeling of Free | Jul 18  | Along the Rideau Canal"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40967/dscf2854_curtis_perry__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Primary Colours is a Canadian piano trio that builds from the traditions of jazz, with influences from modern acts like Robert Glasper, GoGo Penguin, Tigran Hamasyan and Herbie Hancock. Blending acoustic and electric elements, the trio flows between head-nodding grooves and soulful melodies, discovering the unexpected through their improvisational virtuosity. The trio features Deniz Lim-Sersan on keys, Chris Pond on bass and José Hernandez García on drums. \n\nMusic on the Canal \nThe concert takes place on the Rideau Canal beginning near the..."
      }
    ],
