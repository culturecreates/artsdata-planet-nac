    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "GeminiCrab: Malika Tirolien & Caulder Nash  |  Fri, Jun 19, 2026, 6:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40661/ojf_2026_showpass_1200x600_gemini_crab__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "“This is a labour of love, an unforgettable musical journey of HighSoul, R&B, and Jazz-Hip Hop”\n\nWith more than 2.3M views on YouTube and 300K listeners on Spotify, Grammy-nominated vocalist/producer Malika Tirolien, together with Montreal award-winning keyboardist/producer Caulder Nash, present their HighSoul duo GeminiCrab!\n\nThe music is a mix of R&B, Soul, jazz-Hip Hop. The duo playfully reflect on several eras of music through catchy songs about love, adulting and Millennials’ realities.\n\nHailing from Guadeloupe and based in Montreal, Malika Tirolien has made..."
      }
    ],
