    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sophie Grenier | Jukebox Lunch Concerts |  Thu, May 14, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
