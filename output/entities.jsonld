      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dystoh featuring Guiss Guiss Bou Bess  | Axé Summer WorldFest  |  Fri, Jul 17, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41519/dystoh_and_guiss_guiss_bou_bess__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Axé Worldfest and the National Arts Centre join forces to present the 2nd edition of Axé Summer WorldFest 2026 to celebrate global music, diversity, and culture through three unforgettable days of rhythm, connection, and world-class performances in the heart of Ottawa. \n\nDYSTOH is a dynamic new duo from Ray Tabana and Phil Motion, founding members of the three-time Juno-nominated Souljazz Orchestra. Blending hard-hitting congas, roaring baritone sax, and tight two-part harmonies, their sound draws from the commanding and vibrant elements of..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
