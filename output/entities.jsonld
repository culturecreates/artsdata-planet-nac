      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "La Famille Leblanc | The Feeling of Free | Aug 18 - 20, 2026 | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41301/fg_7731r__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Take in a summer sunset with us! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer. \n\nLa famille LeBlanc’s music will take you on a musical journey through Poitou in France, where the Acadians arrived as refugees in the mid-18th century, then on to Louisiana and back to Canada's east coast for a feast of Acadian musicality.   \n\nThis family with Acadian roots plays a variety..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
