    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Allison Russell | with AHI |  Sun, Oct 25, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41399/_mp39488_final_v1_warm2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Montreal-born and Nashville-based, Allison Russell is a Grammy, Juno, Americana and Folk Awards-winning artist, actor, author, songwriter, producer, human rights advocate, survivor and mother. She is the co-founder of Once and Future Sounds and Love Rising. Her debut solo album, Outside Child, was released in 2021, followed by The Returner in 2023 via Concord/Fantasy Records.\n\nPrior to her solo career, she co-founded, recorded and toured internationally with the bands Po’Girl, Birds of Chicago, and Our Native Daughters. She is a member of Joni Mitchell’s Joni..."
      }
    ],
