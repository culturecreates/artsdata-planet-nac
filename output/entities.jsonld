    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "GANNA  | with DIVKA |  Thu, Jun 11, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
