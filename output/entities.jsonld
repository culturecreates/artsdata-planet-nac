    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 Cappies Gala |  Sun, Jun 14, 2026, 6:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41437/cappies__large__event_1440__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Cappies Gala awards ceremony recognizes and honors high-achieving high school theater students from over 20 schools in the Ottawa area. Awards are given for performance, critique, costumes, lighting, choreography, and more.\n\nYou can consult now the 2026 Cappies Nominations."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
