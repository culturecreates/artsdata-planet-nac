    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ottawa Jazz Orchestra | Brilliant Brubeck | Sep 16 - 17, 2026 | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41708/brilliant_brubeck__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join the Ottawa Jazz Orchestra for a captivating tribute to one of the most innovative and beloved figures in jazz history, Dave Brubeck. He was a true pioneer who brought complex, odd time signatures into the mainstream and seamlessly blended classical structures with swinging jazz. This programme expands his legendary small-group compositions into breathtaking, full-scale big band arrangements. You’ll be treated to sweeping renditions of his most iconic and rhythmically daring works. Celebrate the genius of Dave Brubeck with an..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
