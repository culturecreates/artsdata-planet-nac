      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Why Sci-Fi | NACO Family Adventures  |  Sun, May 3, 2026, 3:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38384/web-listing-whysyfi-edit2__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Prepare to blast off with the NAC Orchestra on an intergalactic musical adventure! Experience the thrill and wonder of science fiction brought to life through dazzling works including John Williams's theme from Star Wars, Jesse Montgomery's Starburst, and Debussy's Clair de lune. This cosmic journey will ignite your imagination and take you to the stars and beyond! \n\nWe hope you will enjoy the giant images on the NACOtron screen as they capture and magnify the magic of these fabulous concerts!\n\n----------------------------\n\nPre-Concert Activities\n\nArrive 60 minutes early..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
