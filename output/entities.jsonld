    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 NACO Bursary Semi-Finals | Winds, brass, percussion, and timpani |  Mon, Apr 20, 2026, 1:00 pm | Carleton Dominion-Chalmers Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40203/dscf9625-curtis-perry-3c_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The NAC Orchestra Bursary Competition encourages the pursuit of excellence on the part of young Canadian instrumentalists aspiring to orchestral careers. Join us for the Semi-Finals of the competition, where eight musicians will compete to be included in the finals on April 21!\n\nThe first NAC Orchestra Bursary Competition was in 1981. The Bursary provides recognition and financial support to help further the development of young Canadian orchestral musicians with connections to the National Capital Region. The first year, one prize of $1,000..."
      }
    ],
