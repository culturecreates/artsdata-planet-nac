    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Andrea Lindsay | D’or et d’argent – The Show |  Thu, May 14, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40322/web_resize_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "For singer–songwriter Andrea Lindsay, the past decade has been a time of vibrant creativity and memorable moments on stage. Her 2016 album Entre le jazz et la java, featuring covers of jazz classics and winner of the Félix Award for Jazz Album of the Year, was followed by more than 60 live shows. During the same period, she released two albums in collaboration with Luc De Larochellière, and the duo has since performed together dozens of times.\n\nProduced by Philippe Breault, D’or et d’argent is Andrea’s..."
      }
    ],
