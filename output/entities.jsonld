    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "M&Aacute;M: Teaċ Daṁsa │Michael Keegan-Dolan"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Bringing together virtuoso Irish traditional concertina player Cormac Begley, contemporary music collective s t a r g a z e, and an ensemble of twelve dancers from Tea&#267; Da&#7745;sa, M&Aacute;M overflows with circular energy. At a gathering where music casts a spell, dancers swirl, swoon and surrender in an atmosphere charged with spirit of myth and mythology."
      }
    ],
    "http://schema.org/keywords": [
      {
        "@value": "Dance"
      },
      {
        "@value": "Contemporary"
      }
    ],
