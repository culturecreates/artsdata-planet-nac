    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Tenors | Season of Hope Tour |  Tue, Dec 8, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41728/the_tenors_-_black_background__large.jpeg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "This holiday season, join The Tenors for their Season of Hope Tour, an uplifting concert experience that celebrates the joy, wonder, and connection of the season with some of the most wonderful Christmas songs. \n\nWith their powerful songs, outstanding harmonies, and undeniable charm, The Tenors bring audiences on a musical journey through cherished holiday classics, inspiring original songs, and seasonal favourites. The Season of Hope Tour is a celebration of the traditions that bring us together.\n\nThe Tenors deliver an evening filled..."
      }
    ],
