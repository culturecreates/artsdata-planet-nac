      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Carl Mayotte |  Tue, Apr 28, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40089/pheonix_pagliacci__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Carl Mayotte’s new concert features music from his forthcoming album, Claude. Alongside his band’s signature energy and virtuosity, the show has an added emotional and introspective dimension. Inspired by two pivotal events, the music combines nostalgia and liberation. It’s an experience that will bring both a smile to your face and an ache to your heart. \n\nIntimate and luminous, Carl Mayotte’s Claude was prompted by two significant life events: the fire that destroyed his apartment in 2023 and the death of his father in 2024. From these traumatic experiences emerged music that interweaves nostalgia and the joy of remembering, expressed..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
