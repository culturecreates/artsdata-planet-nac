      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Summer Indigenous Art Market  |  Sun, Jun 7, 2026, 11:00 am | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40927/summer_art_market_2025__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Gather with us on Sunday June 7 from 11am-5pm in the Gail & David O’Brien Atrium as we host Indigenous artists and artisans for the Summer Indigenous Art Market at the National Arts Centre. Join in on the community spirit by supporting artists, seeing friends and connecting with arts and culture.  \n\nThe Indigenous Art Market features the diverse and amazing work of Métis, Inuit and First Nations makers. Browse jewelry, beadwork, paintings, sculptures, mittens, moccasins, coffee, crafts, and much more. Come..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
