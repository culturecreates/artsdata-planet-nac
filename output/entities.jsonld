    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "MayaSpoken | Jukebox Lunch Concerts |  Thu, May 7, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41073/mayaspoken__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "MayaSpoken is a Ugandan-Jamaican poet and singer-songwriter based on the unceded, unsurrendered territory of the Anishinaabe Algonquin Nation. As a slam poet, she is the first woman to become a two-time champion of the Canadian Individual Poetry Slam (CIPS) and ranked second in the Americas. \n\nHer music is a soulful exploration of self-discovery, love and Black culture. Maya hopes that through her art others can be inspired to be voices of disruption, advocacy and change. \n\nThis Jukebox Lunch Concert is presented by..."
      }
    ],
