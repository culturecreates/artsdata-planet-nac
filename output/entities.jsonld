  {
    "@id": "https://nac-cna.ca/en/event/40370#2026-11-13T19:30:00-05:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/DanceEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-11-13T19:30:00-05:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-11-13T21:30:00-05:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Rhino: Out Innerspace"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In Rhino an unlikely cast of characters past their prime &mdash; including a skeleton, rhino, and matador &mdash; jostle to maintain relevance; in their efforts to persist and resist, they unite in their hope, and struggle for a future. Set in a tragicomical dreamscape, seven performers grapple with their fates as they attempt to stand the test of time."
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/40370"
      }
    ],
