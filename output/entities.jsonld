    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Medusa Quartet  | The Feeling of Free |  Thu, Aug 13, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40974/medusa2025_02__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nGet ready to stomp your feet, laugh, cry, and hear sounds you've never heard before with the electrifying chamber-folk band Medusa Quartet. Wielding ancient fiddle-like instruments that could propel classical music scholars right out of their chairs, these four folk musicians are reimagining the..."
      }
    ],
