        "@language": "en",
        "@value": "Schubert&rsquo;s Monumental Ninth Symphony: & Julie Boulianne Sings Berlioz"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A night that builds from intimate romance to the sweeping power of Schubert&rsquo;s monumental Ninth. Julie Boulianne brings Berlioz&rsquo;s Les Nuits d&rsquo;&eacute;t&eacute; to life before the orchestra launches into a symphonic finale that ends in triumph."
      }
