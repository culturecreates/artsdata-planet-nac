    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Daniel Tosh is a comedian, host, writer and producer.\n\nDaniel is widely known for hosting and creating TOSH.0 on Comedy Central. The show showcased internet clips with the addition of Daniel’s comedic perspective and was one of the longest running comedy series for Comedy Central.\n\nHe can currently be heard and seen hosting his video podcast, TOSH SHOW. The show premiered garnering millions of watches and listens in the first weeks.\n\nDaniel has performed live stand-up comedy to sold out venues all over..."
      }
    ],
