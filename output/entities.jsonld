    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Yeison Landero with Special Guests Afrosound and Lady La Profeta | Axé Summer WorldFest  |  Thu, Jul 16, 2026, 7:00 pm | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41521/yeison_landero-b__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Spend your night with us taking in the sunset and vibing to music! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer.   \n\nDue to high demand - for this free Wood Terrace performance only - we are offering pre-registration to secure your seat. We recommend registering for one of the limited guaranteed spots - but don’t worry! There will also be first come first serve spots available, so..."
      }
    ],
