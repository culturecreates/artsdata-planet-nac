  {
    "@id": "https://nac-cna.ca/en/event/38334#2026-06-05T19:30:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/TheaterEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-06-05T19:30:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-06-05T22:00:00-04:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Macbeth: Shakespearean tragedy meets Robert Lepage"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A medieval setting plays host to criminal biker gangs in this grand reinterpretation of Shakespeare&rsquo;s classic, which addresses overwhelming paranoia, political conspiracy and the bloody thirst for power. Under the brilliant gaze of theatrical master Robert Lepage, the ferocious beauty of this bloody tragedy, transposed into 1990s Quebec, remains untempered by time."
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/38334"
      }
    ],
    "http://schema.org/image": [
      {
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38334/tfcna2526_macbeth_1440x810__large.jpg"
      }
    ],
    "http://schema.org/organizer": [
      {
        "@id": "_:g1344940"
      },
      {
        "@id": "http://kg.artsdata.ca/resource/K14-29"
      }
