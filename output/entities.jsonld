    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Pre-Show Chat: Stravinsky Stories | With Christopher Stowell and Ming Luke |  Thu, Oct 29, 2026, 7:00 pm"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41809/pre-show_chat_(2)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for a conversation with the Royal Winnipeg Ballet's Artistic Director Christopher Stowell and Music Director Ming Luke, on Thursday, October 29 at 7 p.m. This discussion is hosted by NAC Dance Executive Producer Caroline Ohrt, in English. It preceedes the evening's presentation of Stravinsky Stories, a glorious ode to Stravinsky, the quintessential ballet composer of the 20th century."
      }
    ],
