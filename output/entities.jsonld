    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "This performance includes two 15-minute intermissions. From Tomson Highway, award-winning Indigenous playwright of The Rez Sisters and Dry Lips Oughta Move to Kapuskasing, comes the musical Rose, the deeply moving and fiercely funny third chapter..."
      }
