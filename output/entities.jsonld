    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "JØY Brandt Featuring Suraras Do Tapajós  | Axé Summer WorldFest |  Sat, Jul 18, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41522/joy_brandt_and_suraras_do_tapajos__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Axé Worldfest and the National Arts Centre join forces to present the 2nd edition of Axé Summer WorldFest 2026 to celebrate global music, diversity, and culture through three unforgettable days of rhythm, connection, and world-class performances in the heart of Ottawa. \n\nØY Brandt is a Brazilian-Canadian singer and songwriter, based in Toronto, who divides her time between Brazil and Canada. \n\nIn 2025, she won the Pernambuco Music Award (Best MPB Single for “A Calma Acalma”) and the Brazilian Music Professionals Award for..."
      }
    ],
