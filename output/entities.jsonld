    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "cicadas | Apr 7 - 18, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38313/cicadas_new_art__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An NAC English Theatre/Tarragon Theatre Co-production in association with fu-GEN Asian Theatre Company\nCo-commissioned by NAC English Theatre and NAC Orchestra \n\nWhat if your house had a mind of its own?\n\nIn 2035, a decade after the Trinity Bellwoods Collapse in Toronto, an investigation into the mysterious disappearance of a young girl leads to a very peculiar house that has sunk into the earth. A flood with no leak, an ominous voice, and hordes of cicadas are only three of the many strange things..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
