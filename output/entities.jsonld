        "@language": "en-ca",
        "@value": "WAR On The Catwalk |  Sat, Mar 7, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39811/catwalk_event__large.jpg"
