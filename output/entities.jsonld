    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Echoes of the Opera | Great Performers Series / Ensemble Studio of the Canadian Opera Company |  Wed, Nov 18, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40674/metaadtemplate_5__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Echoes of the Opera features the young artists of the Canadian Opera Company Ensemble Studio accompanied by pianists in a curated vocal program. This Great Performers event spotlights the next generation of operatic voices. Audiences can expect a selection of arias and ensembles drawn from the operatic tradition. \n\nA focused evening of operatic discovery. A showcase of emerging talent and repertoire highlights."
      }
    ],
