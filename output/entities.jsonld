      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Morgan Toney |  Thu, May 7, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40175/morgantoney-johnbutler-115__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Mi’kmaw were likely the first people that European explorer John Cabot met in 1497 on the East Coast of what would come to be Atlantic Canada. That legacy of welcome, of bridging two worlds, lives on in the songs and fiddling of Cape Breton’s breakout roots artist Morgan Toney. With thousands of years of tradition behind him, Toney melds the Scottish heritage of this Nova Scotian island with Mi’kmaq songs, stories, and language in his own genre of music,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
