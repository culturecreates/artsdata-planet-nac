    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Daniel James McFadyen | with Kieran Campbell |  Sat, Mar 28, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40319/djm_-_oct_2024_wolfville_shoot_-_final_edits-89-min__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Daniel James McFadyen is an award-winning indie-folk artist whose expressive lyricism, charismatic stage presence, and road-worn storytelling have made him one of Canada’s most compelling contemporary voices. His 2025 sophomore album, Back To The Country (LHM Records), marks a defining moment in his artistic evolution—an intimate, organic, and boldly confident full-length that leans into the Americana/Canadiana textures he has grown increasingly known for.\n\nRecorded live off the floor in a cabin on British Columbia’s Shuswap Lake with producer Cole Friesen, the..."
      }
    ],
