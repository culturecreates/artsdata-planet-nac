      {
        "@language": "en-ca",
        "@value": "HYPROV: Improv under Hypnosis  | starring Colin Mochrie and Asad Mecci |  Thu, Nov 12, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
