      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Jane Siberry | Apr 22 - 23, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39947/jane_siberry__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Canadian singer-songwriter Jane Siberry has been inducted into the Canadian Songwriters Hall of Fame and won the Polaris ‘Legends’ Award for her iconic album The Speckless Sky. After a 10-year recording pause, she returns with her 16th album, One Season: In the Thicket of Our Own Unconsciousness, launching November 2025, with a North American tour to follow – and the NAC is on the list! Legendary for hits like Calling All Angels and Mimi On The Beach, Siberry continues to redefine what it means to be an independent, visionary..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
