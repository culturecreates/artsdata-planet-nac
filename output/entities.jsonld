    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sechile Sedare | The Feeling of Free |  Wed, Jul 29, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40973/sese_promo_2025-photo_credit_olya_shendrik_dsc09042__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—the experience is yours to create! \n\nSechile Sedare is on a musical journey that bridges the past and the present, the personal and the universal. This contemporary roots duo featuring sibling songwriters Leela Gilday and Jay Gilday transcends genres and resonates deeply with the spirit of the land they come from. Sechile Sedare—meaning ‘my younger brother, my older..."
      }
    ],
