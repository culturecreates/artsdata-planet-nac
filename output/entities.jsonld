      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Celeigh Cardinal |  Thu, Jun 18, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40843/brayden_treble_photograhy__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Celeigh Cardinal is a JUNO-winning Indigenous singer-songwriter whose rich, soulful voice has earned her national acclaim. Her latest album, Boundless Possibilities, garnered 2025 WCMA nominations for Indigenous Artist and Roots Album of the Year, following multiple CFMA wins and JUNO nods. Her music explores grief, hope, and powerful self-reclamation.\n\nThe NAC would like to acknowledge the generous support of John and Pina Sicard. "
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
