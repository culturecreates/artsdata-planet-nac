    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kleztory |  Sat, Oct 3, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41188/252_epelletier_kleztory__dsc8491_copy_(1)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "With a dazzling stage presence, Kleztory combines the emotion and warmth of klezmer music with a feverish energy that transports audiences into a musical trance. From Europe to Asia and the Americas, the group offers a unique sonic experience and concerts that leave a lasting impression. \n\nKleztory is an explosive meeting of cultures (Russian, Québécois, Canadian), backgrounds (academic and self-taught), and musical influences (classical, jazz, blues, folk). Driven by a deep passion for klezmer, these virtuoso musicians breathe new life into..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
