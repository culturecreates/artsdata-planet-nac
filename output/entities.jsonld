    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41123/soundproof01__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "SoundProof is a powerhouse trio made up of seasoned musicians Caleel Hall (drums), Kevin Pryce (bass), and Leighton Rodney (piano), who collectively bring over a decade of professional experience to the stage. Together, they are SoundProof—a name that says it all: the proof is in their sound.\n\nBlending genres with effortless fluidity, SoundProof draws from a rich musical palette that spans jazz, R&B, gospel, fusion, Latin, pop, and beyond. Their dynamic performances reflect a deep love for the art of improvisation..."
      }
    ],
