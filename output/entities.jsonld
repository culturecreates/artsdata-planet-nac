  {
    "@id": "https://nac-cna.ca/en/event/39307",
    "http://ogp.me/ns/fb#app_id": [
      {
        "@language": "en-ca",
        "@value": "123254964370141"
      }
    ],
    "http://ogp.me/ns#type": [
