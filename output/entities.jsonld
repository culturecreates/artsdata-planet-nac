    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "STAR WARS and beyond | The music of John Williams | Oct 22 - 24, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40413/9169_nac_2627_pops_illustration_3840x2160_starwars__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Feel the power of the Force in John Williams’s legendary music from the Star Wars saga!\n\nSince the release of the first Star Wars film in 1977, the Rebel Alliance’s quest to defeat Darth Vader’s Imperial Forces has taken the world by storm, inspiring audiences with tales of intergalactic heroism, jaw-dropping special effects, and John Williams’s epic orchestral scores.\n\nNow’s your chance to experience five decades of movie magic as conductor Damon Gupton leads the NAC Orchestra in musical selections from nine Star..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
