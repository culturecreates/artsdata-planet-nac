    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Music for a Sunday Afternoon: Spring Edition |  Sun, May 31, 2026, 3:30 pm | Carleton Dominion-Chalmers Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38378/28__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Sink into seriously relaxing weekend vibes as you experience intimate performances from some of your favourite NAC Orchestra musicians. Surrounded by the architectural marvels of the Carleton Dominion-Chalmers Centre—revered for its top-notch acoustics—you'll feast on a program of musical delights."
      }
    ],
