  {
    "@id": "https://nac-cna.ca/en/event/40440#2026-09-25T19:30:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/TheaterEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-09-25T19:30:00-04:00"
