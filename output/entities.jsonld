    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Collected Strands | The Feeling of Free |  Tue, Jul 7, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
