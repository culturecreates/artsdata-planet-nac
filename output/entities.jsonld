    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "& Juliet | Mar 24 - 29, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38562/fphz0_li__large.jpeg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Broadway's most fun hit musical, & Juliet, flips the script on the greatest love story ever told, imagining what would happen next if Juliet hadn’t ended it all over Romeo, and got a second chance at life and love–on her own terms. This audience favorite is created by the Emmy-winning writer of Schitt’s Creek and features a playlist of iconic pop hits from Max Martin and his collaborators, including “Since U Been Gone”, “Roar”, “I Want It That Way”, “Confident”, and more.\n\nAge..."
      }
    ],
