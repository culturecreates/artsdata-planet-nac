    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/40583"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "NACO 2026 Tour - Halifax, Nova Scotia  | Featuring Jeremy Dutcher |  Thu, Apr 16, 2026, 6:30 pm | Rebecca Cohn Auditorium"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40583/dscf2543_curtis_perry-crop_cropped__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "For their 100th tour since the Orchestra’s founding in 1969, the National Arts Centre Orchestra and Music Director Alexander Shelley are joined by multi‑award‑winning Indigenous composer, singer‑songwriter, and pianist Jeremy Dutcher. \n\nThis electrifying program features works by Dutcher, alongside Beethoven’s iconic Fifth Symphony and Polyphonic Lively by Canadian composer Dinuk Wijeratne. \n\nPlus, Nova Scotia’s own Emma Stevens takes the stage with the NAC Orchestra to perform her viral Mi’kmaw‑language version of “Blackbird,” as well as her powerful original song, “The Ballad of Shubenacadie.” \n\nThe National Arts Centre would like to thank Lead Donor R.N.C. Tennant, Frank..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
