    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kellylee Evans | Winter Song | Dec 10 - 11, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41636/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Juno Award-winning vocalist and songwriter Kellylee Evans brings the magic of the holiday season to life with her latest album, Winter Song. Featuring timeless classics like “All I Want For Christmas Is You,” “Rocking Around the Christmas Tree,” and “Have Yourself a Merry Little Christmas,” the album blends the warmth of jazz with the richness of soul, all infused with Evans' signature vocal prowess. Each track radiates the spirit of the holidays, offering fresh, emotive interpretations of beloved standards. \n\nCo-produced by..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
