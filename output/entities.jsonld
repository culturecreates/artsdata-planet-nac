      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Rose | Book, lyrics & music by Tomson Highway | Mar 25 - Apr 4, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38352/rose__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "From Tomson Highway, award-winning Indigenous playwright of The Rez Sisters and Dry Lips Oughta Move to Kapuskasing, comes the musical Rose, the deeply moving and fiercely funny third chapter in his acclaimed “rez” cycle. NAC Indigenous Theatre is honoured to bring to the stage the professional world premiere!\n\nSet on the fictional Wasaychigan Hill Reserve, the stories of three Roses bloom. The first Rose has just become chief, determined to assert her authority while preserving the integrity of her Indigenous culture...."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
