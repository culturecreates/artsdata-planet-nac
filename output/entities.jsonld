      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sarah Hagen | Goldberg Variations |  Fri, Oct 16, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41584/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Sarah Hagen brings this classic programme featuring Bach’s formidable Goldberg Variations as part of the celebration of the recent release of her recording of the masterwork.  \n\nCherished by many, the Goldberg Variations are emblematic of keyboard virtuosity, rich expression, and hardcore classical interpretation. Sarah will offer a short introduction to this marvellous and intense piece before playing the full work. "
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
