    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Post-show Dance Party: Traditional music and dance with La Déferlance and Yaëlle Azoulay"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Danse CNA vous convie &agrave; un party trad dans le foyer du Canal afin de prolonger l&rsquo;exp&eacute;rience du spectacle&nbsp;M&Aacute;M&nbsp;du chor&eacute;graphe irlandais Michael Keegan-Dolan (Tea&#267; Da&#7745;sa). Au son de la musique traditionnelle qu&eacute;b&eacute;coise jou&eacute;e en direct par le groupe La D&eacute;ferlance, la calleuse de renom Ya&euml;lle Azoulay vous guidera par sa voix afin de vous initier aux pas de base de la danse traditionnelle."
      }
    ],
