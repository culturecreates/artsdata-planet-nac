      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "danses vagabondes | Louise Lacavalier │Fou Glorieux | Oct 14 - 15, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40368/web-6__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Untethered and Unstoppable\n\nLouise Lecavalier’s latest solo has enraptured audiences in Canada and Europe. In danses vagabondes she wanders the back alleys of her vast creative repertoire, uncovering a treasury of embodied movement and gestures, weaving together past, future, and present. Her dance unfolds as an ongoing dialogue between instinct and precision, freedom and discipline, unleashing raw joy out of the pure freedom of dance.\n\nA luminous and riveting presence, Lecavalier’s performance is ecstatic, merging precision and instinct with dynamic tension. Hypnotic..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
