      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "À poils  | Explosive, immersive stage experience you can dive straight into | Oct 31 - Nov 1, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40431/tfcna2627_apoil_1920x1080__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Don’t miss this mind-blowing Unidentified Furry Object from France! To the sound of electric guitars, three rather tough-looking stage technicians begin to load in equipment and summon us to help them. Then a spectacular transformation takes place, revealing the gentle and colourful animal hidden behind each shaggy beast!\n\nThe first impression is unsettling: an empty theatre, tour crates rolling around randomly, a security cordon. Did they skimp on the set design? Not only that, the three burly stage techs expect us..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
