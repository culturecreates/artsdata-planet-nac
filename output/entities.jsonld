    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Toddler Tuesdays |  Tue, May 12, 2026, 10:00 am | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40569/toddler_tuesdays_1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Singing, dancing, games, story time and more! Toddler Tuesdays are the perfect morning activity for children aged 18 months - 5 years and the parents/caregivers who love them! Join instructor Jesse Kahat in Peter A. Herrndorf Place for a fully interactive exploration of the performing arts through creative play. \n\nBiography – Jesse Kahat  \n\nJesse Kahat: (she/her) Jesse is an actor, director, choreographer, dance instructor, and music teacher. She has a BA in Theatre Directing from the University of Northern Colorado and an MA in..."
      }
    ],
