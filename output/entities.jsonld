    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Oxbow Trio | The Feeling of Free |  Tue, Jul 28, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41290/dscf6274_curtis_perry(1)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nFormed by three friends during the pandemic, the Oxbow Trio found in chamber music a creative refuge that quickly grew into a deeply rewarding artistic collaboration. Violinist David Thies-Thompson and cellist Leah Wyber, both familiar faces from the National Arts Centre Orchestra, join pianist..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
