    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Makoto Ozone Plays Rachmaninoff: and Gemma New conducts Pictures at an Exhibition"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Take in a trio of orchestral remixes in which composers vividly reimagine the work of other musicians and artists &mdash; from a flashy fiddle tune to a gallery of haunting paintings."
      }
