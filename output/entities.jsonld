      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dominique Fils-Aimé | The Sunshine Tour |  Wed, Mar 4, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39931/websize__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Rising star in vocal jazz and double JUNO Award winner, Dominique Fils-Aimé is a Montreal singer-songwriter who puts the history of African-American musical culture into the heart of her work. She will perform a show that invites the audience to delve into the roots of her soul with a strong desire to connect with one's higher self. Whether in Canada (in a double bill with Allison Russell at Toronto's Koerner Hall), in Europe (opening for Melody Gardot, Diana Krall, and Ibrahim Maalouf),..."
      }
    ],
