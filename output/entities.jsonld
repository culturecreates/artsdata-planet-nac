    ],
    "http://ogp.me/ns#url": [
      {
        "@language": "en-ca",
        "@value": "https://nac-cna.ca/en/event/40350"
      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mehdi Cayenne |  Tue, Mar 24, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40350/4_1768325857_photo_live_credit_vincent_assie-1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A free spirit of the international Francophonie, Mehdi Cayenne pulls us into an irresistible whirlwind of feel-good new songs that radiate charm.\n\nHis sharper-than-ever lyrics are powered by electro-pop infused with local and global influences – a combination that’s as compelling as it is unique on the Quebec cultural scene.\n\nWelcome to the Cayenne Club: prepare to be stirred and shaken, peppered and cayenned – it’s quite a ride!\n\nThe NAC would like to acknowledge the generous support of John and Pina Sicard. "
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
