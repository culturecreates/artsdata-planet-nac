    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Camions (fantômes de la liberté) | An audio walking tour | Apr 8 - 19, 2026 | Azrieli Studio Foyer"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38325/tfcna2526_camions_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Adults, youth from age 9 welcome.\n\nFrench audio track, with English passages. \n\nAudio walking tour for 1 to 3 people at a time, starting at the Foyer Fountain. Departures take place every 15 minutes, according to the following schedule: from 5pm to 7:30pm on weekdays, and from 11am to 3:45pm on weekends. You will be able to choose your departure time when purchasing tickets.\n\nBreaking news: Following the winter 2022 protests, we’re hearing that the NAC is about to be INVADED BY..."
      }
    ],
