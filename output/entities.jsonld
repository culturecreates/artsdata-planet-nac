    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Spooky Symphony | NAC Orchestra Family Adventures |  Sun, Oct 18, 2026, 3:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40421/2460x1440-spooky2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "It’s all treats, no tricks inside Southam Hall!\n\nFrom an excerpt from The Sorcerer’s Apprentice to the theme from Ghostbusters and other hair-raising tunes, this concert is sure to cast a spell on you this Halloween. Principal Youth Conductor and Community Ambassador Daniel Bartholomew-Poyser, the NAC Orchestra, and special guests bring spooky orchestral favourites to life in a fang-tastic performance. \n\nLike our musicians, come decked out in your best costume—but be sure to park your broom at the door!\n\nWe hope you will enjoy the giant images on..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
