    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 Cappies Gala |  Sun, Jun 14, 2026, 6:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
