  {
    "@id": "https://nac-cna.ca/en/event/38325#2026-04-08T17:00:00-04:00",
    "@type": [
      "http://schema.org/Event"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-04-08T17:00:00-04:00"
