    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Mozart&rsquo;s &ldquo;Jupiter&rdquo; Symphony sets the stage ablaze with brass fanfares, and cellist Bryan Cheng evokes the glamour of Hollywood&rsquo;s Golden Age."
      }
