    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Capital Sessions | Free community house dance practice |  Sun, Mar 22, 2026, 1:30 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40267/capital_sessions__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Capital Sessions and the NAC are bringing you a series of FREE community house dance workshops.\n\nIt's family and beginner-friendly. The DJ plays deep soulful house music from 1:30 to 3:30 pm and the dancer leads two 30-minute workshops at 1:30 and 2:30 pm. You can just dance, learn or listen and vibe out - it's a beautiful space with amazing music!\n\nNo experience required. FREE."
      }
    ],
