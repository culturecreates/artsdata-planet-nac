    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Voice of Desert: Saburo Teshigawara | KARAS"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Saburo Teshigawara has been revered by audiences for decades. Voice of Desert, his most recent work, is about the cycle of life, which he describes as &lsquo;a piece created to touch the soul of human beings.&rsquo;"
      }
    ],
