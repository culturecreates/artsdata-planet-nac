    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "danses vagabondes: Louise Lacavalier │Fou Glorieux"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Louise Lecavalier&rsquo;s latest solo has enraptured audiences around the world. In danses vagabondes she wanders the back alleys of her vast creative repertoire, uncovering a treasury of embodied movement and gestures, weaving together past, future, and present."
      }
    ],
