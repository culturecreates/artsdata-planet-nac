    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Stravinsky Stories: Canada’s Royal Winnipeg Ballet"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "In this special evening, Stravinsky&rsquo;s compositions will be brought to life on stage in two one-act ballets: Firebird, composed in 1910 for Diaghilev&#39;s Les Ballets Russes, and The Fairy&rsquo;s Kiss, composed in 1928 for Les Ballets de Madame Ida Rubinstein."
      }
    ],
