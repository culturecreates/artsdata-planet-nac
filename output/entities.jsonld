    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Resonance: Korean Cultural Centre 10th Anniversary Concert | Gonia, Dosi and Maria Kim |  Sat, Jul 18, 2026, 7:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41244/nac1_3540_2160__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "To commemorate the 10th anniversary of the Korean Cultural Centre Canada, this special concert celebrates the significant milestone and a decade of cultural achievements, while looking forward to a brighter future.\n\nOn this occasion, Gonia, Dosi and Maria Kim have travelled from Korea to showcase the richness and depth of traditional Korean music. Through this event, the Korean Cultural Centre Canada aims to further promote cultural exchange and foster a deeper appreciation of Korean heritage in Canada.\n\nTicket Information\nTo ensure that this..."
      }
    ],
