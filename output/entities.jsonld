    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Avishai Cohen Big Vicious | Jun 25, 2026  | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40347/4_1768323459_copy_of_3_-_avishai_cohen_2024_-_daniella_feijoo__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Avishai Cohen is a globally recognised trumpeter and composer known for his distinctive sound, adventurous spirit, and boundary-pushing approach to contemporary jazz, working widely as a leader, collaborator, and sideman with projects including his quartet, Triveni, the Mark Turner Quartet, SFJAZZ Collective, and the 3 Cohens Sextet alongside his siblings Anat and Yuval Cohen. In 2024, he released Ashes to Gold, a deeply introspective album inspired by life’s transitions and renewal, drawing on the Japanese concept of Kintsugi to transform..."
      }
    ],
