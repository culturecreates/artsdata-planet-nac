    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Laura Niquay | Nir Wactenama |  Thu, Nov 26, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41619/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Four years after igniting stages with over 100 concerts across the country, Laura Niquay returns with Nir Wactenama, a powerful show where blues and rock collide with rare intensity. Carried by mesmerising vocal harmonies and the raw energy of an all-female band, she electrifies the stage alongside Raphaëlle Chouinard (Les Shirley) on guitar, Sarah Dion (Les Shirley) on drums, and Marie-Philippe Thibault-Desbiens (Princesses) on bass. Tailor-made for live performance, this vibrant and energetic show blends distorted riffs, raw emotion, and..."
      }
    ],
