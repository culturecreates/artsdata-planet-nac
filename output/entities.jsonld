    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "David Suzuki’s Playlist | With the NAC Orchestra, in association with Why Not Theatre |  Tue, Sep 22, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40397/metaadtemplate_10_(5)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Featuring a playlist curated and hosted live by David Suzuki, this special NAC Orchestra concert brings music and meaning together in a powerful new way.\n\nNow 90 years old, David Suzuki is one of Canada’s most respected public intellectuals and environmental activists, and has spent decades helping people rethink their relationship with nature, science, and the future of our planet. For this event, he steps into the role of musical curator, sharing a personal selection of works that have inspired his..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
