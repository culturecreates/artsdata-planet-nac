    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Yeison Landero with Special Guests Afrosound and Lady La Profeta | Axé Summer WorldFest  |  Thu, Jul 16, 2026, 7:30 pm | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41521/yeison_landero-b__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Spend your night with us taking in the sunset and vibing to music! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer.   \n\nAxé Worldfest and the National Arts Centre join forces to present the 2nd edition of Axé Summer WorldFest 2026 to celebrate global music, diversity, and culture through three unforgettable days of rhythm, connection, and world-class performances in the heart of Ottawa. \n\nFrom the..."
      }
    ],
