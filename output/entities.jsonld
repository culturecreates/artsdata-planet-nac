      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Louis-Jean Cormier |  Sat, Apr 25, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40072/pheonix_pagliacci__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Louis-Jean Cormier burst onto the music scene in the late 1990s as a member of the band Karkwa. That chapter of his career came to an end in 2011 (only to pick up again later) with the band’s third album, Les Chemins de verre. He released his first solo album, Le Treizième Étage, in September 2012. Les grandes artères, notably featuring the single Si tu reviens, was released three years later, further boosting his status, which was also helped by his role as a coach on La Voix. In 2020, his father’s death set the central theme of Quand la nuit tombe, followed in 2021 by Le ciel est au plancher...."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
