    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Daniel Tosh | My First Farewell Tour |  Sat, Jun 27, 2026, 7:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
