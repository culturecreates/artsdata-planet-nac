    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "An Evening with David Sedaris | Bestselling Author & Humorist  |  Sun, Sep 27, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40918/(1)_ds_2022_credit_anne_fishbein-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "David Sedaris is one of America’s pre-eminent humour writers. He is a master of satire and one of today’s most observant writers.  \n\nBeloved for his personal essays and short stories, David Sedaris is the author of the New York Times bestsellers Barrel Fever, Holidays on Ice, Naked, Me Talk Pretty One Day, Dress Your Family in Corduroy and Denim, When You Are Engulfed in Flames, Let’s Explore Diabetes with Owls, Calypso, and Happy-Go-Lucky. The audio version of Happy-Go-Lucky, written and narrated..."
      }
    ],
