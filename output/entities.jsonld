    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Roch Voisine | The Lightfoot Sessions |  Sat, Nov 7, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41214/roch-voisine1__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Acclaimed Canadian singer-songwriter Roch Voisine returns to the stage with The Lightfoot Sessions, a new concert experience paying tribute to the legendary Gordon Lightfoot. Reimagining some of the most iconic songs in the Canadian songbook, Roch brings a fresh and intimate perspective to Lightfoot’s timeless repertoire, while revisiting highlights from his own celebrated career.\n\nThe performance features classics such as “If You Could Read My Mind,” “Sundown,” and “The Wreck of the Edmund Fitzgerald,” alongside Roch Voisine favourites including “With These..."
      }
    ],
