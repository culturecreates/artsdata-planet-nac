    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Collected Strands: Room for Wonder | The Feeling of Free |  Tue, Jul 7, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41088/collected-strands-tone_25-26__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Bring your lunch and join Collected Strands for a free noon hour concert in the Atrium! \n\nThis newly-formed group who get together to play improvised chamber music, with a kind of modal-groove-oriented vibe, are sure to delight. \n\nCollected Strands is an improvising chamber music ensemble composed of four fantastic musicians expressing sounds ranging from contemporary modal grooves to classical, folk, experimental, and ambient music. Leah, the violinist, has been a member of NACO since 1997 and is known worldwide as the..."
      }
    ],
