    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Brahms X Radiohead | with the NAC Orchestra |  Tue, Nov 17, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40392/stevehackman_radiohead-021769722542_cropped__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Brahms X Radiohead is an epic symphonic synthesis of Radiohead’s album OK Computer and the Brahms First Symphony, composed for full symphony orchestra and three solo vocalists. The piece offers a reimagined experience of each work by seeing it through the lens of the other, exploring the explosive tension and deep pathos they have in common.\n\nBrahms’s 19th-century orchestral sound palette is used throughout, but woven in, superimposed, and inserted are the melodies and music of Radiohead. At times, one hears the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
