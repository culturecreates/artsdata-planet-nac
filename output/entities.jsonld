      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Philippe B |  Sat, Nov 28, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41222/web_resize_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Occupying a musical space somewhere between the sophisticated songs of Leonard Cohen, Jacques Brel and Félix Leclerc, the rustic folk of Bob Dylan, Neil Young and Richard Desjardins, the acoustic pop of Simon & Garfunkel, and the haunting melancholy of Nick Drake and Elliott Smith, Philippe B reminds us that depth can be conveyed with nothing more than a guitar and a few words. His seventh album, Cigale, released in March 2026, shows him at his most authentic and personal...."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
