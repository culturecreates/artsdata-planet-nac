      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Flávia Nascimento and Tio Chorinho | The Feeling of Free | Jul 21 - 23, 2026 | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40946/2021-tiochorinho-flavia-03-credit-zahrasalecki__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Texto em português após o inglês \n\nSpend your night with us  soaking up a sunset! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer. \n\nFlávia Nascimento and Tio Chorinho deliver a vibrant, high-energy performance blending Brazilian choro, samba, forró, and original compositions. Audiences can expect virtuoso musicianship, soulful vocals, dynamic rhythms, and playful improvisation. Flávia’s infectious stage presence brings audiences into the performance, often interacting..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
