    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Gentiane MG |  Thu, Nov 12, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41612/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Gentiane MG is a Montreal pianist and composer known for emotionally resonant piano trio music that bridges contemporary jazz and classical influences. With her long-standing trio, she presents Can You Hear the Birds?, a project shaped by connection, listening, and shared human experience.  \n\nThe music explores themes of presence, resilience, forgiveness, and renewal, unfolding through intuitive interplay and collective improvisation. Rooted in an ear-based creative process, the trio’s performances are fluid, open, and deeply connected, inviting audiences into a space of attention, curiosity, and emotional..."
      }
    ],
