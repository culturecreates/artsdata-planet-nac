    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Cranium Conference & Showcase 2026 | Day 1 |  Fri, May 8, 2026, 6:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41121/day_1_nac_2-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Cranium Arts Project is excited to announce the Cranium Conference and Showcase 2026. \n\nThe two-day music event will connect active industry professionals with musicians, artists and people making moves in the arts and entertainment business. The weekend will feature networking sessions, information panels with music professionals, masterclasses, and a showcase featuring some great emerging talent.\n\nSchedule: Friday, May 8, 2026 \n\n6:00 – 7:45 pm: Face the Music \n\nFourth Stage – FREE, no registration required  \nDuring this facilitated networking session, music industry professionals from Ottawa, across Canada,..."
      }
    ],
