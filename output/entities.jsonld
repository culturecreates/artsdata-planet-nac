      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Macbeth | Shakespearean tragedy meets Robert Lepage | Jun 5 - 13, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38334/tfcna2526_macbeth_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "At a time when the news is glorifying the triumph of billionaire despots, Robert Lepage tackles the famous Scottish tragedy, which addresses overwhelming paranoia, political conspiracy and the bloody thirst for power. Coincidence? The medieval setting plays host to criminal biker gangs from 1990s Quebec in this grand reinterpretation of Shakespeare’s classic, whose ferocious beauty and dreadful curse remains untempered by time.\n\nCawdor Castle becomes a rural motel, and Birnam Wood looks like a cannabis field, but the original prophetic tale..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
