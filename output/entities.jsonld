      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "John Cleese and the Holy Grail at 50 | Not dead yet! | Oct 9 - 10, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40850/cleese_venue_2426x1365__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An Unmissable Night of Absurdity, Laughter, and Legendary Comedy!\n\nJoin us for an unforgettable evening as we celebrate 50 years of Monty Python and the Holy Grail with the one and only John Cleese! This once-in-a-lifetime event features a special screening of the beloved cult classic, Monty Python and the Holy Grail, followed by an uproarious conversation and audience Q&A with Cleese himself, where he’ll share behind-the-scenes stories, wit, and wisdom—assuming he remembers any of it.\n\nVIP Ticket Holders will also gain exclusive access to a special..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
