      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Pre-Show Chat with Hope Muir and Bobbi Jene Smith | Hosted by NAC Dance Executive Producer Caroline Ohrt |  Thu, Apr 23, 2026, 7:00 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41008/pre-show_chat_procession__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for a conversation with choreographer Bobbi Jene Smith and Hope Muir, The National Ballet of Canada's Joan et Jerry Lozinski Artistic Director, on Thursday, April 23 at 7 p.m. in the Peter A. Herrndorf Place. This discussion is hosted by NAC Dance Executive Producer Caroline Ohrt, in English. It preceedes the evening's presentation of Procession in Southam Hall. "
      }
    ],
