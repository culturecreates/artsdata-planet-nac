      {
        "@language": "en",
        "@value": "Th&rsquo;owxiya: The Hungry Feast Dish: By Joseph A. Dandurand"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Th&rsquo;owxiya tells the thrilling tale of a trickster mouse who must embark on a daring quest to outwit an ancient spirit to save his family. A music-filled adventure for all ages!"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/38355"
      }
    ],
