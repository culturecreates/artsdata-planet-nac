    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "k.d. lang: has always been | An Evening Celebrating a Musical Legacy  |  Fri, Oct 2, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40498/kd_poster_0528_web-b__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "On October 2, a stellar array of acclaimed artists will gather on the Southam Hall stage to honour Canadian icon k.d. lang. Dedicated to the voice, the vision and the enduring impact of one of Canada’s most distinctive and influential artists, k.d. lang: has always been is the definitive celebration of a monumental talent.\n\nWith landmark albums like Ingénue and Hymns of the 49th Parallel, notable collaborations with icons such as Tony Bennett and Roy Orbison, and a catalogue that includes..."
      }
    ],
