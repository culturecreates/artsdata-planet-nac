    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kimmortal |  Tue, Jul 28, 2026, 7:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41358/kimmortal-web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Queer Filipinx Kimmortal's artistry is defined by its subversive energy and grounded vulnerability, navigating between singing and rapping over layered hip-hop beats. Their third album Shoebox (2023), chronicles their journey through healing intergenerational trauma, celebrating the 2SLGBTQ+ community, and embracing their inner child. Their new EP, sunniest of days (released in 2025), held the number one spot on the !earshot hip hop charts for eight weeks. Featuring collaborations with Shad, Super Duty Tough Work, and Junia-T, the project processes both..."
      }
    ],
