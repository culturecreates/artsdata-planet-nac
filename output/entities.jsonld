    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ottawa Jazz Orchestra | Supremely Shorter | May 16, 2026  | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/39367/ojo__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Experience the enduring legacy of Wayne Shorter, a 12-time Grammy winner whose colossal talent as a jazz saxophonist and composer left an indelible mark on music. From his pivotal roles in Art Blakey’s Jazz Messengers, Miles Davis’ Second Great Quintet, and the influential jazz fusion band Weather Report, Shorter consistently pushed boundaries. Many of his brilliant compositions are now cornerstones of the jazz standards canon. For our season finale, a 15-piece band from the Ottawa Jazz Orchestra will perform innovative..."
      }
    ],
