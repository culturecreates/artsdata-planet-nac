    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "CBC Massey Lectures 2026 | Housing Inc.: A Global Takeover and Our Fight for Home |  Thu, Oct 29, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41745/cbc_2026masseylectures_1920x1080_(3)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "After all these years and all these recommendations, why are we still in a housing crisis? Why haven’t we been able to build our way out of the problem? If we’ve collectively lost our way, how do we find our way back home? \n\nIn the 2026 CBC Massey Lectures, Housing Inc.: A Global Takeover and Our Fight for Home, Leilani Farha reckons with a crisis engineered by governments and perfected by financial firms.\n\nIn her fifth and final lecture, she argues we..."
      }
    ],
