    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Becca Stevens Trio |  Fri, Jun 19, 2026, 7:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41115/copy_of_ojf_2026_showpass_1200x600_becca_stevens_trio__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Twice GRAMMY-nominated singer-songwriter and multi-instrumentalist Becca Stevens is a genre-defying artist whose work seamlessly weaves together jazz, pop, indie-rock, and her Appalachian roots. Since founding her band in 2006, she has become a premiere collaborator for musical luminaries such as David Crosby, Jacob Collier, and Michael League. Her latest album, Maple to Paper (2024), marks a profound shift toward raw vulnerability, featuring stripped-back, live performances that explore themes of grief and transcendence. Whether making her Broadway debut in Sufjan Stevens’..."
      }
    ],
