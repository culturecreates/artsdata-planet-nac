    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Beaded Vamp and Moccasin Workshop | with Colleen Nolan | May 5 - 19, 2026 | Atelier Shenkman Smith"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40673/beaded_moccasin_workshop_event_image__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Vamp and Moccasin Workshop with Colleen Nolan offers a unique opportunity for individuals to learn the art of crafting moccasins with a beaded vamp. This workshop provides participants with hands-on experience in crafting and constructing their own pair of moccasins.  \n\nParticipants leave with not only a beautiful pair of handmade moccasins but also pride. Whether you're a beginner or an experienced crafter, this workshop is open to all. It will be a fun and welcoming environment, where stories will be..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
