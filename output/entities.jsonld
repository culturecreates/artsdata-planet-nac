      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Joshua Bell & Alexander Shelley | with the NAC Orchestra | Apr 8 - 9, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38412/7__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three things to know:\n\n\n\tViolinist Joshua Bell brings together five of today’s leading composers to celebrate the beauty of our natural world in The Elements.\n\tBased on a tragic medieval legend, Richard Wagner’s opera Tristan und Isolde explores the enduring mysteries of love, death, and eternity.\n\tFeel the rhythms of the mambo and cha-cha in wildly colourful dances from Leonard Bernstein’s score to West Side Story.\n\n\nIn The Elements, Grammy Award–winning violinist Joshua Bell pays tribute to the four classical elements—Earth, Fire, Water, and Air—and..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
