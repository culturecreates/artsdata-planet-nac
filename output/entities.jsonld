    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Lennie Gallant | The Innkeeper's Christmas |  Sat, Nov 28, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
