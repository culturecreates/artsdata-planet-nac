    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The Irish Descendants | Tribute to Stan Rogers |  Sat, Oct 31, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41599/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Irish Descendants’ tribute to Stan Rogers is a heartfelt celebration of one of Canada’s most enduring songwriters. Rooted in deep respect and a shared musical lineage, the album honours Rogers’ powerful storytelling and the timeless themes of sea, land, and community that resonate so strongly in Newfoundland and Labrador. With rich arrangements, warm harmonies, and performances by Rowan Sherlock, Jeff Kinsman, Madeline Carter, and Con O’Brien, the project carries Rogers’ legacy forward for new listeners while offering longtime fans..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
