    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Miguel de Armas | The Feeling of Free |  Tue, Aug 4, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40966/dscf0317_curtis_perry__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists. \n\nJoin internationally acclaimed Cuban pianist Miguel de Armas for an unforgettable evening of live Latin music at the National Arts Centre. This special performance goes beyond the music — it’s an interactive journey into the heart of Latin rhythms, instruments, and traditions. \n\nMiguel and his band will take you through a dynamic repertoire, from the lively beats of..."
      }
    ],
