  {
    "@id": "https://nac-cna.ca/en/event/38349#2026-03-19T20:00:00-04:00",
    "@type": [
      "http://schema.org/Event",
      "http://schema.org/TheaterEvent"
    ],
    "http://schema.org/startDate": [
      {
        "@value": "2026-03-19T20:00:00-04:00"
      }
    ],
    "http://schema.org/endDate": [
      {
        "@value": "2026-03-19T22:00:00-04:00"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Visages: Based on true stories"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Incredible true stories become entangled with the concept of the human face, an entity made of skin and yet a gateway to the soul. With a magnetic cast of performers, the luminous Alexia B&uuml;rger premieres a spellbinding choral work that splinters the concept of identity to reveal each glittering facet."
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/38349"
