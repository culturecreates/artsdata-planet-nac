    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Carole Pope |  Sat, Oct 24, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41598/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A documentary on Carole’s life based on her autobiography Anti Diva, produced by CBC and Gay Agenda, is set to hit theatres in 2026. Guests include kd lang, Peaches, Sebastian Bach, Rufus Wainwright, Nona Hendryx, Strombo, Jann Arden and more. Carole Pope and Kevan Staples’s band Rough Trade was inducted into Canada’s Walk of Fame in 2023. On the Polaris Prize short list, Carole Pope is an agent provocateur pushing the boundaries of sexuality, sexual politics, and the status quo...."
      }
    ],
