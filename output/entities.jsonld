    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Brandon Woody’s UPENDO |  Sun, Jun 21, 2026, 6:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40349/250114-brandonwoody-05__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Brandon Woody is a Baltimore-born, Bach-endorsed trumpeter, composer, and bandleader whose music draws from the lineage of Black music—jazz, gospel, improvisation, and beyond—to explore themes of love, resilience, and community. Praised by The New York Times and Los Angeles Times as a rising force in contemporary jazz, Woody signed with Blue Note Records in 2024 and released his debut album, For The Love Of It All (2025), featuring his longtime band Upendo. Rooted in Baltimore’s creative community, his work has..."
      }
    ],
