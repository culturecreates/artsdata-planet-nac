      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Mommy, le retour  | Gore, rap and political musical satire | Sep 25 - 26, 2026 | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40440/tfcna2627_mommy_1920x1080__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "She may have died in a long-term care facility, but she comes back to life to wreak revenge! Is she a traditional mother or a reactionary mummy? Mommy, that bogeywoman of ideals invented by the mad scientist of theatre, Olivier Choinière, is resurrected as the high priestess of a ceremony sung and rapped by neo-fascist zombies portrayed by remarkable, hyper-energized performers.\n\nA messianic DJ lords it over a stage set that looks like a glitzy bazaar. A pair of narrators straight out of..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
