    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "GeminiCrab: Malika Tirolien & Caulder Nash"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Grammy-nominated vocalist-producer Malika Tirolien, together with award-winning&nbsp;Montreal keyboardist-producer Caulder Nash, present their HighSoul duo GeminiCrab!&nbsp;With a mix of R&amp;B, Soul, jazz-Hip Hop, the duo playfully reflects on several eras of music through catchy songs about love, adulting and Millennial realities."
      }
    ],
