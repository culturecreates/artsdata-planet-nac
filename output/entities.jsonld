    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "2026 NACO Bursary Finals | Winds, brass, percussion, and timpani |  Tue, Apr 21, 2026, 1:00 pm | Carleton Dominion-Chalmers Centre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40204/dscf5974-curtis-perry-2_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Thanks to the generosity of the members of the NAC Orchestra and of additional organizations and individuals, laureates will be chosen from the semi-finals to compete in the finals for the following prizes:\n\n\n\tThe NAC Orchestra Bursary\n\tThe Crabtree Foundation Award,\n\tThe Friends of the NAC Orchestra Award\n\tThe NAC Orchestra Vic Pomer Award\n\tThe Dorothy M. Horwood Award\n\tThe Friends of the NAC Orchestra Evelyn Greenberg Award\n\tThe Piccolo Prix\n\tThe Sturdevant Prize for Orchestral Excerpts \n\n\nThe first NAC Orchestra Bursary Competition was in 1981. The Bursary provides recognition and financial..."
      }
    ],
