    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "UNDERTALE: The Determination Symphony |  Sat, Nov 21, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41531/2426x1365__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "UNDERTALE: The Determination Symphony is an unforgettable concert experience featuring the most memorable themes from the hit indie game, newly arranged and performed live by 25 musicians of the FILMharmonique Orchestra. With gameplay footage displayed on a screen above the stage, audiences will be fully immersed in the world of UNDERTALE, experiencing its story and music like never before.\n\nToby Fox, creator and composer of UNDERTALE, shared his excitement:"
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
