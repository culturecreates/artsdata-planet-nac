    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Matteo Lane | We Gotta Catch Up Tour |  Fri, Nov 6, 2026, 7:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41169/matteolane_ott,on_2426x1365__large.jpeg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "MATTEO LANE is a multifaceted talent known for his unique blend of stand-up comedy, musical prowess and artistic versatility. Hailing from Chicago, Lane’s comedic journey has taken him from New York City comedy clubs to sold-out performances across the globe, including Carnegie Hall and The Kennedy Center. His next stand up special will debut on Hulu in May 2025.\n\nPreviously named as one of Variety’s “10 Comics to Watch” and described by Advocate as “bold and unflinchingly genuine,” Lane tackles a..."
      }
    ],
