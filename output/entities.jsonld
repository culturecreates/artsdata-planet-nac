    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Disney's Pirates of the Caribbean: The Curse of the Black Pearl, Live in Concert | with the NAC Orchestra | Jul 9 - 11, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38422/dc_poc_12_(1)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Presented in English with French subtitles\nPlease note that Under30 tickets are limited for these performances.\n\nThe National Arts Centre Orchestra presents Disney’s Pirates of the Caribbean: The Curse of the Black Pearl, featuring Klaus Badelt and Hans Zimmer’s score performed live to the film.   \n\nOscar and Grammy Award-winning composer Hans Zimmer and his production team have scored each Pirates of the Caribbean adventure for the franchise. The original score raised the bar for thematic complexity with its orchestral swashbuckling flavour accentuated by the use of horns..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
