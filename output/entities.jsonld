      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "An Evening with Whitehorse featuring Chloë Doucet | All Of It Tour |  Sat, May 30, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40842/whitehorse_-_2026_promo__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "For the first time, Whitehorse hit the road as a true family band — a full-circle moment where two decades of music-making now spans generations on stage. \n\nWith their new album All I Want Is All of It, Whitehorse return to the sound that first defined them: folk-rock romanticism, raw storytelling, and the lived-in chemistry of two decades spent writing, touring, and building a life together. Recorded in a farmhouse setting with an emphasis on instinct over perfection, the album captures the duo at..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
