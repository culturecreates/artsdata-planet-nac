      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Roxanne Goodman  | The Feeling of Free |  Sat, Aug 15, 2026, 4:30 pm | Along the Rideau Canal"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40968/roxanne_goodman_-_photo__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Get ready for an unforgettable performance with Roxanne Goodman!\n\nA magnetic entertainer with a voice that moves effortlessly between jazz, gospel, blues, and pop, Roxanne knows how to light up any stage. She brings her vibrant energy to everything from community celebrations to corporate events, weddings, and even large‑scale flash mobs—always leaving audiences smiling and fully immersed in the moment. \n\nA seasoned composer and producer, Roxanne brings heart and creativity to every note she performs. She holds a Baccalaureate in Music from..."
      }
    ],
