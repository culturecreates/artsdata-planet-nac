      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Schubert’s Monumental Ninth Symphony | & Julie Boulianne Sings Berlioz | Apr 29 - 30, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38415/dscf0040_curtis_perry_(1)_cropped__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "What you need to know:\n\n\n\tSchubert’s monumental Ninth Symphony anchors the evening with a sweeping, high-energy journey that builds toward a powerful, triumphant finale.\n\tThe first half explores French romantic intimacy through Berlioz’s Les Nuits d’été, performed by mezzo-soprano Julie Boulianne.\n\tA night that moves from close, expressive storytelling to full symphonic scale: cinematic, emotional, and immersive.\n\n\nThe evening culminates in Franz Schubert’s Symphony No. 9, often called “The Great,” a monumental work that expanded the scale and ambition of the symphony. From its..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
