      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Passion simple | An intimate tale of waiting | May 7 - 9, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38337/tfcna2526_passionsimple_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Three theatrical stars sparkle in a rare alignment: a brilliant director, a radiant actress and the Sun herself, Annie Ernaux, the masterful chronicler of anonymous others. Using her pen as a scalpel, she dissects a heart consumed by passion: her own.\n\nMany of us have read and reread the work of literature Nobel prize winner Ernaux, but how many of us have ever heard it performed on stage? Unyielding theatrical mastermind Brigitte Haentjens has invited the stellar Julie Le Breton to..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
