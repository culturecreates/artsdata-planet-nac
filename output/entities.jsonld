    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "cicadas unearthed  |  Sat, Apr 11, 2026, 6:30 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41097/nina_unearthed__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "What if a radio play became a live theatre show, a video game and a documentary? \n\nJoin us for a lively, informal presentation exploring multiplatform storytelling and its intersection with theatre and performance.\n\nRooted in a partnership between NAC English Theatre, the Metcalf Foundation and Sheridan College, this discussion focuses on cicadas as the case study for an ongoing multiplatform research project.  Speakers will unearth the theory and rationale behind multiplatforming, and explore how a radio play, PC/VR video game, and documentary can all intersect with the stage work to..."
      }
    ],
