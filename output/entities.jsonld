      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Chamberfest’s Bring the Kids!  | Beth Silver & Jenna Richards  |  Mon, Jul 27, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41289/chamberfest-kids__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nDiscover the magic of music with cellist Beth Silver and pianist Jenna Richards in a lively, imaginative concert for children and families. Known for their warm, engaging style and inclusive approach, this beloved duo brings together everything from maritime fiddle tunes and traditional Klezmer..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
