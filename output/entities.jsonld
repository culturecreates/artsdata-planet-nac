    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Te Tangi a Te Tūī | By Tainui Tukiwaho and Amber Curreen | Jun 4 - 7, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38356/tangui_credit_emily_cooper__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "In this stunning circus piece, we experience the story of Aotahi who lives peacefully on her ancestral land, in Aotearoa (New Zealand), near a forest shrouded in mystery. Within its depths lurk the Patupaiarehe, supernatural fairy-like beings, and Kōiriiri, the Bird Man—a creature bound by an ancient curse. When Aotahi gives birth to her son, Piri, the first male in their family line for generations, his arrival awakens a long-dormant curse.\n\nAs Piri grows up, he becomes the focus of two..."
      }
    ],
