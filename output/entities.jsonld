    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Class on Stage with The National Ballet of Canada |  Sat, Apr 25, 2026, 1:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
