    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Waahli |  Sat, Apr 11, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40594/web_resize__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Waahli is a Montreal-based artist of Haitian origin whose musical inspiration is rooted in a childhood enriched by traditional melodies. However, it is through hip-hop culture that he finds his voice and develops a unique and captivating style.  \n\nIn 2024, Waahli was nominated for the 2024 Juno Awards for Best Album of the Year in the Global Music category. \n\nSE7EN BUBBLES is an album that marks a musical evolution and the exploration of new territories for Waahli in 2025. It is accompanied by eclectic sound aesthetics ranging from traditional Haitian fusion to..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
