      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Beyond Earth: A Conversation with the Artemis II Crew |  Wed, May 13, 2026, 1:30 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41394/nhq20260401_admin_0005~orig__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The National Arts Centre is honoured to welcome the Artemis II astronauts to Ottawa for a rare public conversation exploring humanity’s return to the Moon.\n\nHear from Canadian Space Agency astronaut Jeremy Hansen, joined by NASA astronauts Reid Wiseman, Victor Glover, and Christina Koch, alongside CSA astronaut Jenni Gibbons, the first Canadian-certified Artemis capcom.\n\nThis rare conversation offers insight into the Artemis program, international collaboration in space exploration, and what lies ahead as humans prepare to return to the Moon.\n\nWe expect the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
