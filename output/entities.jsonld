    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Pride Pageant |  Sat, Aug 22, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41763/capitalpridepageant2026__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us as local drag performers compete for the titles of Mr., Mx., and Ms. Capital Pride 2026. Hosted by Cyril Cinder, and judged by Yovska, Suki Doll, and Hercusleaze. Also joining us is the 2025 Royal Court, Ms. Capital Pride 2025 Portia Züm Züm, Mr. Capital Pride 2025 Zak Zinya, and Mx. Capital Pride 2025 Banshii. You don’t want to miss their step-down performances!\n\n2026 Contestants:\n\nMR.\nAustin Paradise\nCaleb O'Guy\nEgo Stroker\nFrancis Coe\nPrince Vic\n\nMS.\nBae Root\nEsther Royd\nKarma k\nShea Muah\nYeti\n\nMX.\nOpal Essence\nMizrabelle\nMx. Tique\nRip Em\nVex Scandal\n\nThis event..."
      }
    ],
