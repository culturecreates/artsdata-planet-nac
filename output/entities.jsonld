    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Suraras do Tapajós – The Carimbó Workshop Experience | An Interactive Workshop on the Music, Dance, and Culture of the Amazon |  Fri, Jul 17, 2026, 5:00 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41852/suraras_caixasp_41dsc_7540-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "O português segue o inglês\n\nJoin Suraras do Tapajós, the first Indigenous women’s Carimbó group from the Brazilian Amazon, for an immersive cultural experience that goes far beyond the music.\n\nThrough live demonstrations, storytelling, rhythm, movement, and audience participation, this interactive workshop explores the rich traditions of Carimbó and the cultural heritage of the Amazon. Participants will discover traditional instruments, percussion patterns, dance, song, and the ancestral knowledge that connects music, territory, identity, and community.\n\nThe workshop also invites reflection on environmental stewardship,..."
      }
    ],
