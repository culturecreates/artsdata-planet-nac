      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kellylee Story & Song Series: SALIN |  Sat, Jun 27, 2026, 5:15 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41756/kellylee-square-salin_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join award-winning vocalist and interviewer Kellylee Evans for a special series of free, intimate artist talks featuring candid conversations with some of today’s most innovative jazz musicians. This rare, artist-to-artist series offers a deep dive into the creative process and the art of jazz, featuring exclusive sessions with:\n\n\n\tBobby Previte (June 25 at 4 PM)\n\tMyra Melford (June 26 at 4 PM)\n\tSALIN (June 27 at 5:15 PM)\n\tJodi Proznick of Ostara Project (June 28 at 5:15 PM)"
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
