      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Benin International Musical  | The Power of Vodoun at the Heart of Modern Music  |  Tue, Jul 14, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41226/bim_salford_press_-_guillaume_robin__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "BIM (Benin International Musical) brings together five musician‑vocalists who share stories of the African continent and its histories through a powerful blend of sound and storytelling. Rooted in Beninese culture and the voodoo tradition, the group challenges common misconceptions, drawing on voodoo’s life‑affirming philosophy and its deep connection to land and community. Fusing rock and rap with traditional rhythms, BIM transforms each performance into a contemporary ritual. \n\nAfter a debut album that took them around the world for more than 150..."
      }
    ],
