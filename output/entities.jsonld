    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Gentiane MG |  Thu, Nov 12, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
