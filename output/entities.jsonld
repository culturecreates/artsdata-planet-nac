      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Les souvenirs du sable | Quand la tempête est fabuleuse  | Jul 7 - 11, 2026 | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40969/les_souvenirs_du_sable_image1_credit-alexandre_donato__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Les souvenirs du sable is a tale of the depths of grief and the strength of children, recounting the story of a little girl named Alma, who has to navigate the crashing waves of her inner world. \n\nBack on the islands where she was born, Alma sifts through memories of her dad, swallowed up by the wind and the sea. Alma searches through the storm inside her for the key to her treasure—the relationship she lost and the happiness that vanished...."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
