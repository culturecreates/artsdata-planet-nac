      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Duo LéNo |  Sat, Oct 24, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41597/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A fascinating, no-holds-barred, uncompromising piano-and-drums duo with vocals. A truly “complete” album: crank it up to full volume and listen to the sounds bursting forth—the haunting strings, the snare drums and cymbals that shimmer, ping, clatter, and crackle.  \n\nOne might have thought that, with just two musicians, something would be missing. But nothing is. Carried along by rhythm and dance, spellbound by the piano’s ostinatos, its cascades and leaps into the void, the mind lets go. \n\nA world where two musicians sound..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
