      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Norma Winstone with the Atlantic Jazz Collective |  Thu, Jun 25, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40346/atlantic_jazz_web__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The Atlantic Jazz Collective is a group of three Juno Award-winning Canadian artists—saxophonist Mike Murley, bassist Jim Vivian, and pianist Florian Hoefner—who have returned to Atlantic Canada after careers in Toronto and New York. Born from the Atlantic Jazz Nights concert series in St. John’s, the group is dedicated to developing and promoting jazz locally and internationally. Their debut album, Seascape (Alma Records, May 2025) features acclaimed UK vocalist Norma Winstone and Ottawa drummer Nick Fraser, presenting reimagined works by Maria..."
      }
    ],
