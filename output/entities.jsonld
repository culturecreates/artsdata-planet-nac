    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Royal Wood x Fortunate Ones | The Have a Heart Tour |  Wed, Apr 15, 2026, 7:30 pm | Babs Asper Theatre"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40056/untitled_design_(4)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Longtime fans of each other, Royal Wood and Fortunate Ones are tired of being touring ships passing in the night. Both are musical miners of the heart, so they decided to call this The Have a Heart Tour. It’s been a long time coming, but well worth the wait!\n\n-\n\nSinger, songwriter and multi-instrumentalist Royal Wood returns with his new album Dear John, available now. Described as “a letter to himself,” the record reunites him with five-time Grammy winner Ryan Freeland and..."
      }
    ],
