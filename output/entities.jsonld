    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Céleste Lévis | Si elle |  Thu, Sep 24, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
