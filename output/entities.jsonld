    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Visages | Based on true stories | Mar 19 - 28, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38349/tfcna2526_visages_1440x810__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "An exact doppelgänger of Vladimir Putin lives in Poland. Each morning, this fervent supporter of the Ukrainian cause contemplates the Enemy’s reflection in the mirror. Are we our faces? This is the starting point for the luminous Alexia Bürger, who, in the wake of her unforgettable trio in Les Hardings, takes a new look at the improbable connections binding the fates of people whom the world seems to keep apart. With Visages—premiering at the NAC—Bürger creates a spellbinding choral work in which the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
