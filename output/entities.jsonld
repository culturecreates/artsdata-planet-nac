      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Rheostatics have been one of Canada’s most original and unpredictable bands since forming in 1979. With a dozen acclaimed albums to their name, including the beloved Whale Music and the landmark Music Inspired by the Group of Seven, they’ve built a reputation for blending rock, folk, prog, and pop into something uniquely their own. Along the way, they’ve scored a Genie Award and Juno Award, and inspired countless Canadian musicians, developing a loyal following that treasures them as a national..."
      }
    ],
