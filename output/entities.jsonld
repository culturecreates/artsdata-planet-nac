    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Chamberfest presents uOttawa Nicole Senécal Prize Winner: Nathaniel Mears | The Feeling of Free |  Tue, Jul 28, 2026, 12:00 pm | Atrium O’Brien"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41290/chamberfest_nac_senecalprize_nathanielmears__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Enjoy a free, music-filled midday break in the O'Brien Atrium. Bring your meal, grab a spot, and experience incredible live performances by talented artists—it's the perfect way to refuel your energy for the rest of the day! \n\nThe 2026 Nicole Senécal Emerging Artist is percussionist Nathaniel Mears, who recently completed his Master’s of Music at the University of Ottawa. In November 2025, he was named Principal Percussionist of the Saskatoon Symphony Orchestra.\nThe Nicole Senécal Emerging Artist Award honours an outstanding graduating..."
      }
    ],
