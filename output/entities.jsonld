    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dance for All  | International Dance Day Workshop |  Wed, Apr 29, 2026, 12:00 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41137/d09b9ecd-bc91-4102-9125-2b30c58b8d28__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Come one and all to celebrate the joy of movement on International Dance Day! \n\nNAC Dance Teaching Artist, Siôned Watkins will take you through a simple contemporary dance warm up followed by an easy breezy choreography that will leave you feeling uplifted. \n\nLearn a simple choreography and dance with us!  All are welcome, no experience needed.  \n \n "
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
