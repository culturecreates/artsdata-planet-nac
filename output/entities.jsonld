      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Spring Craft Market | Mother’s Day edition |  Sun, Apr 26, 2026, 11:00 am | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40846/spring_market_01__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join us for another edition of the Spring Craft Market, a vibrant showcase of local creative culture. Shop from a curated selection of handmade goods, makers, producers and artists, all while supporting small businesses in our community. It’s the perfect opportunity to buy your Mother’s Day gifts!\n\nThe market runs from 11 am – 4 pm.\n\nFree to attend. Onsite parking. Accessible venue."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
