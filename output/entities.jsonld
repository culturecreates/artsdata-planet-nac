    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "True Mountain Laurel | Haley Blais & Sam Lynch |  Sat, Sep 19, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41853/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Haley Blais and Sam Lynch unite as True Mountain Laurel, a supergroup born from late-night harmonies, voice memos, and friendship. Their debut project, Angel So Bad, blends Sam’s poetic introspection with Haley’s sharp lyrical intimacy into dust-swept folk-country songs that capture longing, growth, and connection. \n\nWhat began as casual writing sessions evolved into a collaborative ritual: trading lines over coffee, recording scrappy demos, creating music free from pressure or pretense. Influenced by Gillian Welch, Lucinda Williams, and early 2000s Canadian singer-songwriters,..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
