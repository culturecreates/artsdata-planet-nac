      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Stravinsky Stories | Canada’s Royal Winnipeg Ballet | Oct 29 - 31, 2026 | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40371/stravinsky_hero__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "With the NAC Orchestra\n\nFrom Folklore to Fantasy\n\nFor Christopher Stowell’s first programmed season as RWB’s new artistic director, he brings us this glorious ode to Stravinsky, the quintessential ballet composer of the 20th century.  \n\nIn this special evening, Stravinsky’s compositions will be brought to life on stage in two one-act ballets: Firebird, composed in 1910 for Diaghilev's Les Ballets Russes, and The Fairy’s Kiss, composed in 1928 for Les Ballets de Madame Ida Rubinstein. Often described as revolutionary, Stravinsky’s work is..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
