    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sara Curruchich |  Tue, Oct 20, 2026, 8:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41694/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "El español sigue al texto en inglés\n\nBorn in San Juan Comalapa (1993), Sara Curruchich is a Maya Kaqchikel singer, songwriter, and activist who creates songs inspired by her culture and roots, blending her two languages: Kaqchikel, her mother tongue, and Spanish. With subtlety and great skill, she weaves together folk and rock sounds with the musical elements of her people, continuing a tradition of resistance. Her life, and that of her community, has always been a testament to resilience. \n\nSara, the..."
      }
    ],
