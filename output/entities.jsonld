    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Kim Churchill | The Lovely Tour with Mia Kelly | Apr 1 - 2, 2026 | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40010/websize_(1)__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Kim Churchill embarks on the Canadian leg of  'The Lovely Tour' in the spring of 2026! Following the release of his latest album, It's Lovely To Have You Here, Kim has been touring the globe on the Lovely Tour, presenting the new songs alongside all people's favourites from the past. Armed with his 3 campervans, Kim travels across countries telling his stories and drawing people into the adventure of his nomadic and musical existence. Be prepared for a dazzling one-man band..."
      }
    ],
