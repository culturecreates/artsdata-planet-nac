      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Classic Albums Live: Madonna | The Immaculate Collection |  Fri, Aug 21, 2026, 8:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40599/web_resize__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Classic Albums Live takes the greatest albums and recreates them live on stage – note for note, cut for cut, using the best musicians. Forgoing costumes and impersonations, Classic Albums Live has found success in concentrating solely on the music.\n\nThe Immaculate Collection is the first greatest hits album by American singer Madonna, released on November 12, 1990, by Sire Records. It contains fifteen of her hit singles recorded throughout the 1980s, as well as two brand new tracks,"
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
