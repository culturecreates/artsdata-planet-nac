    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Desi Dhamaka | A Celebration of South Asian Arts & Culture   |  Sat, May 30, 2026, 12:00 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41136/desi-image1_web__event_1440__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Free event – Everyone is welcome! \n\nGet ready for the second edition of Desi Dhamaka: A Celebration of South Asian Arts and Culture!\n\nAfter a vibrant and successful first edition, Desi Dhamaka returns with an even bigger celebration of South Asian creativity and community. Enjoy beautiful performances on stage featuring dance and music, experience the colours and energy of South Asian culture, and explore a lively community market showcasing crafts, jewelry, design, and more.\n\nBring your friends and family and join us for..."
      }
    ],
