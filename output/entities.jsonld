      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Son of a Preacherman | Written and performed by Ins Choi | Sep 16 - 26, 2026 | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40378/soap-main_web__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "A Pacific Theatre Production\n\nForgive him Father for he has chosen theatre. \n\nIns Choi, the creator of Kim’s Convenience, comes from a long line of clergy. Before he was born, his mother made an offering to God that if she had a son, he would dedicate his life to the church. Turns out both God and Ins had other plans. Behold the triumphant return to the stage of one of theatre’s greats, as he riffs on Bible stories, his creative process, and growing..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
