        "@language": "en",
        "@value": "Spooky Symphony: NAC Orchestra Family Adventures"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "It&rsquo;s all treats, no tricks inside Southam Hall! Principal Youth Conductor and Community Ambassador Daniel Bartholomew-Poyser, the NAC Orchestra, and special guests bring spooky orchestral favourites to life in a fang-tastic performance."
      }
