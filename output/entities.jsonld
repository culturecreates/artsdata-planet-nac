    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Turkwaz & Medusa  | The Feeling of Free | Aug 11 - 13, 2026 | Wood Terrace"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40970/turkwazpromo3__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Spend your night with us under the stars! Access our terrace directly from Elgin Street, the canal, or the Mackenzie King Bridge and take in the best free beats offered in Ottawa this summer. \n\nWhat do you get when you unite four feisty string players with four magnificent vocalists? A wild musical alchemy that lifts up Gorgons and Hags, reclaiming their legendary power. Together, Medusa and Turkwaz fuse polyphony, harmony, heterophony, and daring rhythmic play to create Hagerophony—a rich and resonant..."
      }
    ],
