    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Flore Laurentienne |  Sat, Jun 27, 2026, 6:30 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40343/flore_web__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Rooted in the Québec landscape and inspired by the vastness of the St. Lawrence River, Flore Laurentienne creates a richly lyrical sound that blends strings and analogue synthesisers, drawing from influences as varied as Bach’s counterpoint, King Crimson’s progressive intensity, and experimental electronic minimalism. Led by composer and keyboardist Mathieu David Gagnon and brought to life on stage by a seven-piece ensemble, the project balances emotional depth with dynamic textures, seeking resonance over complexity.\n\nSince the release of Volume I (2020),..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
