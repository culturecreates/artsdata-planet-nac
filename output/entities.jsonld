    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Sherri Harding | Storyland Album Launch with Special Guest Shawn Tavenier |  Tue, Jun 16, 2026, 7:30 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40844/sherri_harding_promo_photo_2026_(hr)__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Join Sherri Harding for a special evening celebrating the release of her highly anticipated new album Storyland.\n\nWith an all-star 12-piece band behind her, Harding brings depth, nuance, and her signature vocal performance to the stage.\n\nRooted in blues, soul and R&B, the show offers a compelling mix of stellar songwriting and dynamic live performance.\n\nOne night only. Don’t miss it."
      }
    ],
