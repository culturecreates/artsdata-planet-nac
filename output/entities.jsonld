    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Geneviève RB | Jukebox Lunch Concerts |  Thu, Jun 4, 2026, 12:10 pm | Peter A. Herrndorf Place"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41076/genevieve_rb_web_event__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Geneviève RB is a Franco-Ontarian singer-songwriter and performer based in Quebec. Known for her expressive voice and radiant presence, she creates French-language pop songs where catchy melodies meet emotional depth. \n\nShe first gained recognition as part of the duo Geneviève et Alain, with whom she released three albums, toured across the Canadian Francophonie, and received multiple honours, including three Trille Or awards and a Canadian Folk Music Award in 2023. \n\nIn 2024, Geneviève RB began her solo career, allowing her to fully embrace her..."
      }
    ],
