    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dana Sipos |  Thu, Oct 22, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41654/rounded_corner_design__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Known for crafting music that is both intimate and otherworldly, acclaimed Canadian songwriter Dana Sipos’ talent for earthen imagery, rich, spiralling vocals, and textured instrumentation sets the stage for a deeply moving performance. She has brought her cosmic folk to living rooms, concert halls and festival stages across North America, Europe, the UK, Australia and New Zealand. Her previous release, The Astral Plane, was lauded as a “mesmerising jewel of an album” by No Depression and garnered Sipos a Solo Artist of the Year..."
      }
    ],
