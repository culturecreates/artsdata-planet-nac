    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Dance at Zibi – Tango with Siempre Tango Ottawa |  Thu, Aug 20, 2026, 7:00 pm | Head Street Square – Zibi"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/41562/tango_02__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "On August 20, take your first steps in Argentine Tango with the team from Siempre Tango Ottawa. Learn to create a great abrazo (embrace) and to improvise movements with your fellow dancers. Your teachers will also share some of the secrets of tango subculture, so you'll feel more comfortable attending any future tango event. This summer, embrace the unexpected with Siempre Tango Ottawa!\n\nDance at Zibi event series\n\nDance at Zibi is back for another season of rhythm, movement, and community. \n\nIn partnership..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
    ],
