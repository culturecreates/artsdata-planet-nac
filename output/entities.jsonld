      }
    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "The National Ballet of Canada – YOU dance Performance for Families | How a Ballet Comes to Life |  Sat, Apr 25, 2026, 12:00 pm | Southam Hall"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40885/2023_169_(300)-2__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "The National Ballet of Canada’s YOU dance program is designed to introduce families and youth to the theatrical art of ballet.  \n\nFeaturing The National Ballet of Canada’s RBC Apprentices, and accompanied by a pianist and a host, this curated one-hour performance of both classical and contemporary works on the Southam Hall stage is a wonderful learning opportunity for families and students of all ages.\n\nAudiences will have the opportunity to meet the RBC Apprentices, learn about the pieces being performed, gain insight into the life of a professional dancer and discover the..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
