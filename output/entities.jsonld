      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Agamemnon in the Ring: Wrestling in verse"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Twelve imposing wrestlers take the stage to defend this electrifying reinterpretation of the Trojan War in Qu&eacute;b&eacute;cois alexandrine verse, the brainchild of the impertinent Hilaire St-Laurent. This adaptation of an ancient epic in the form of a wrestling rumble will unleash your inner beast. It&rsquo;s catharsis in the ring!"
      }
    ],
    "http://schema.org/url": [
      {
        "@value": "https://nac-cna.ca/en/event/38322"
      }
    ],
