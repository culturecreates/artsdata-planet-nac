    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Rose: Book, lyrics & music by Tomson Highway"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "From award-winning playwright Tomson Highway comes Rose, the powerful final chapter in his &ldquo;rez&rdquo; cycle. Blending humour, music, and deep emotion, this world premiere follows three Roses whose stories intertwine as they fight for identity, justice, and the soul of their community."
      }
