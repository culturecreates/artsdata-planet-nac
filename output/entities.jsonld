    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "WolfGANG Sessions #29  | A Wild Night of Chamber Music |  Sat, Jun 20, 2026, 9:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/38381/8789_nac_wolfgang29_peach__large.jpg"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "WolfGANG Sessions are nights of music that are sure to entertain. Grab your adventurous friends and take them out for a wild night of chamber music with your favourite musicians from the NAC Orchestra.\n\n\nA special edition at the NAC Fourth Stage!"
      }
    ],
