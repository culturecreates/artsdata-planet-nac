    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Orrin Evans Trio |  Wed, Jun 24, 2026, 7:00 pm | Azrieli Studio"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
