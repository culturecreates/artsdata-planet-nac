    ],
    "http://ogp.me/ns#title": [
      {
        "@language": "en-ca",
        "@value": "Ivan Boivin-Flamand |  Thu, Dec 3, 2026, 8:00 pm | Fourth Stage"
      }
    ],
    "http://ogp.me/ns#image": [
      {
        "@language": "en-ca",
        "@value": "https://naccnaca-eventimages.s3.amazonaws.com/40836/web_resize__large.png"
      }
    ],
    "http://ogp.me/ns#description": [
      {
        "@language": "en-ca",
        "@value": "Ivan Boivin-Flamand is back in the spotlight with a brand new microalbum, Nitehi, and a brand new show. Accompanied by his band, the poet, singer–songwriter and virtuoso guitarist with a keen musical instinct delivers a captivating performance. A familiar face on television and on tour in Quebec, Ivan presents Nitehi (meaning “my heart” in Atikamekw, his native language), a selection of meticulously composed, deeply personal songs. His ethereal and unique voice gives his pop-rock songs a captivating folk-soul feel.\n\nA unique..."
      }
    ],
    "http://ogp.me/ns/fb#admins": [
      {
        "@language": "en-ca",
        "@value": "728780803"
      }
